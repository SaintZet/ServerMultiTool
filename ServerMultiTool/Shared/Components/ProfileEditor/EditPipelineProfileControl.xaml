                                    <TextBox Style="{StaticResource FieldTextBoxStyle}" Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Expander>
                    <Expander Header="Build" Style="{StaticResource SectionExpanderStyle}">
                        <StackPanel Margin="2,8,2,8">
