        <!-- WebBrowser editor -->
        <DataTemplate x:Key="WebBrowserEditorTemplate">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="14,10">
                    <Expander Header="General" IsExpanded="{Binding DataContext.IsOperationGeneralExpanded, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" Style="{StaticResource SectionExpanderStyle}">
                        <StackPanel Margin="2,8,2,8">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Name" />
                            <TextBox Margin="0,0,0,10" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Description" />
                                    <TextBox Style="{StaticResource FieldTextBoxStyle}" Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Expander>
                    <Border Margin="0,6,0,0" Padding="8,6" Background="#FFF8E7" BorderBrush="#FFE082" BorderThickness="1" CornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center" Data="{StaticResource Information}" Fill="#F5A623" Stretch="Uniform" />
                            <StackPanel>
                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#8A6000" Text="Tip" />
                                <TextBlock FontSize="11" Foreground="#8A6000" Text="Changes are saved automatically" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>
        <converters:OperationEditorTemplateSelector x:Key="OperationEditorTemplateSelector" DeliveryBinTemplate="{StaticResource DeliveryBinEditorTemplate}" DeliverySpecifiedFilesTemplate="{StaticResource DeliverySpecifiedFilesEditorTemplate}" GitPullTemplate="{StaticResource GitPullEditorTemplate}" HttpPingTemplate="{StaticResource HttpPingEditorTemplate}" MsBuildTemplate="{StaticResource MsBuildEditorTemplate}" ProcessExecutionTemplate="{StaticResource ProcessExecutionEditorTemplate}" SqlExecutionTemplate="{StaticResource SqlEditorTemplate}" WebBrowserTemplate="{StaticResource WebBrowserEditorTemplate}" />
    </UserControl.Resources>
    <Grid Background="{DynamicResource TertiaryBackgroundColor}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" MinWidth="170" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="1.0*" MinWidth="180" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="1.85*" MinWidth="260" />
            </Grid.ColumnDefinitions>
            <!-- LEFT: Pipeline -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource PanelHeaderBorderStyle}">
                    <TextBlock Style="{StaticResource PanelHeaderTitleStyle}" Text="Pipeline" />
                </Border>
                <Expander Grid.Row="1" Margin="14,10,14,8" Header="General" IsExpanded="{Binding IsPipelineGeneralExpanded, Mode=TwoWay}" Style="{StaticResource SectionExpanderStyle}">
                    <StackPanel Margin="2,8,2,8">
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Name" />
                        <TextBox Margin="0,0,0,10" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding Profile.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Description" />
                        <TextBox Margin="0,0,0,10" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding Profile.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Expander>
                <Border Grid.Row="2" Style="{StaticResource PanelHeaderBorderStyle}" BorderThickness="0,1,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource PanelHeaderTitleStyle}" Text="Steps" />
                        <Button Grid.Column="1" VerticalAlignment="Center" Command="{Binding AddStepCommand}" Content="Add Step" Style="{StaticResource SmallAddButtonStyle}" />
                    </Grid>
                </Border>
                <ListView x:Name="StepsListView" Grid.Row="3" AlternationCount="1000" AllowDrop="True" Background="Transparent" BorderThickness="0" DragOver="ListView_DragOver" Drop="ListView_Drop" ItemsSource="{Binding Profile.Steps}" PreviewMouseLeftButtonDown="ListView_PreviewMouseLeftButtonDown" PreviewMouseMove="ListView_PreviewMouseMove" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto" SelectedItem="{Binding SelectedStep, Mode=TwoWay}">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="4,2" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="itemBorder" Padding="0" Background="{TemplateBinding Background}" CornerRadius="4">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#DCE6FF" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#EEF3FF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Rectangle Width="2" HorizontalAlignment="Center" Fill="LightGray" />
                                <Ellipse Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{DynamicResource TertiaryBackgroundColor}" Stroke="{DynamicResource SecondaryBlueColor}" StrokeThickness="2" />
                            </Grid>
                            <Border Grid.Column="1" Margin="8,0,0,0" Padding="10,8" BorderThickness="1.5" CornerRadius="6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource TertiaryBackgroundColor}" />
                                        <Setter Property="BorderBrush" Value="LightGray" />
                                        <Setter Property="Opacity" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsSelected}" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource SecondaryBlueColor}" />
                                                <Setter Property="Background" Value="#EFF4FF" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                <Setter Property="Opacity" Value="0.65" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="36" Height="36" Margin="0,0,10,0" Background="{DynamicResource SecondaryBackgroundColor}" CornerRadius="18">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource SecondaryBlueColor}" Text="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ListViewItem}, Converter={StaticResource IncrementConverter}}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextColor}" Text="{Binding Name}" />
                                        <StackPanel Margin="0,2,0,2" Orientation="Horizontal">
                                            <Ellipse Width="7" Height="7" Margin="0,0,5,0" VerticalAlignment="Center" Style="{StaticResource EnabledStateDotStyle}" />
                                            <TextBlock VerticalAlignment="Center" Style="{StaticResource EnabledStateTextStyle}" />
                                        </StackPanel>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource PrimaryGrayColor}" Text="{Binding Description}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Button Grid.Column="2" Width="24" Height="24" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Command="{Binding DataContext.RemoveStepCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Content="" Cursor="Hand" Style="{StaticResource DeleteButtonStyle}" ToolTip="Remove step" />
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <Border Grid.Row="4" Margin="8" Padding="8,6" Background="{DynamicResource SecondaryBackgroundColor}" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4">
                <StackPanel Orientation="Horizontal">
                    <Path Width="12" Height="12" Margin="0,1,6,0" VerticalAlignment="Top" Data="{StaticResource Information}" Fill="{DynamicResource SecondaryBlueColor}" Stretch="Uniform" />
                    <StackPanel>
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextColor}" Text="Drag and drop steps to reorder" />
                        <TextBlock FontSize="10" Foreground="{DynamicResource PrimaryGrayColor}" Text="The pipeline will be executed from top to bottom." />
                    </StackPanel>
                </StackPanel>
            </Border>
            </Grid>
            <Border Grid.Column="1" Background="LightGray" />
            <!-- MIDDLE: Step + Operations -->
            <Grid Grid.Column="2">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedStep}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Hidden" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource PanelHeaderBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource PanelHeaderTitleStyle}" Text="Step" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,2,0" VerticalAlignment="Center" Orientation="Horizontal">
                            <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource PrimaryTextColor}" Text="{Binding SelectedStep.Enabled, Converter={StaticResource BoolToEnabledDisabledTextConverter}}" />
                            <ToggleButton IsChecked="{Binding SelectedStep.Enabled, Mode=TwoWay}" Style="{StaticResource ToggleButtonStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Expander Grid.Row="1" Margin="14,10,14,8" Header="General" IsExpanded="{Binding IsStepGeneralExpanded, Mode=TwoWay}" Style="{StaticResource SectionExpanderStyle}">
                    <StackPanel Margin="2,8,2,8">
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Name" />
                        <TextBox Margin="0,0,0,10" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding SelectedStep.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Description" />
                        <TextBox Margin="0,0,0,10" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding SelectedStep.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Expander>
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource PanelHeaderBorderStyle}" BorderThickness="0,1,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextColor}" Text="Operations" />
                            <StackPanel Grid.Column="1" Margin="0,0,0,1" Orientation="Horizontal" VerticalAlignment="Center">
                                <ComboBox Width="150" Height="28" Margin="0,0,6,0" DisplayMemberPath="Name" FontSize="12" ItemsSource="{Binding AvailableOperationTypes}" SelectedItem="{Binding SelectedOperationType, Mode=TwoWay}" Style="{DynamicResource ComboBoxStyle}" />
                                <Button Command="{Binding AddOperationCommand}" Content="Add Operation" Style="{StaticResource SmallAddButtonStyle}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl Margin="12,8" AlternationCount="1000" ItemsSource="{Binding SelectedStep.Operations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <Rectangle Width="2" HorizontalAlignment="Center" Fill="LightGray" />
                                        <Ellipse Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{DynamicResource TertiaryBackgroundColor}" Stroke="{DynamicResource SecondaryBlueColor}" StrokeThickness="2" />
                                    </Grid>
                                    <Border Grid.Column="1" Margin="8,0,0,0" Padding="10,8" BorderThickness="1.5" CornerRadius="6" Cursor="Hand">
                                        <Border.InputBindings>
                                            <MouseBinding Command="{Binding DataContext.SelectOperationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" MouseAction="LeftClick" />
                                        </Border.InputBindings>
                                         <Border.Style>
                                             <Style TargetType="Border">
                                                 <Setter Property="Background" Value="{DynamicResource TertiaryBackgroundColor}" />
                                                 <Setter Property="BorderBrush" Value="LightGray" />
                                                 <Setter Property="Opacity" Value="1" />
                                                 <Style.Triggers>
                                                     <DataTrigger Value="True">
                                                         <DataTrigger.Binding>
                                                             <MultiBinding Converter="{StaticResource ObjectEqualityConverter}">
                                                                 <Binding Path="DataContext.SelectedOperation" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                                 <Binding />
                                                             </MultiBinding>
                                                         </DataTrigger.Binding>
                                                         <Setter Property="BorderBrush" Value="{DynamicResource SecondaryBlueColor}" />
                                                         <Setter Property="Background" Value="#EFF4FF" />
                                                     </DataTrigger>
                                                     <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                         <Setter Property="Opacity" Value="0.65" />
                                                     </DataTrigger>
                                                 </Style.Triggers>
                                             </Style>
                                         </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="36" Height="36" Margin="0,0,10,0" Background="{DynamicResource SecondaryBackgroundColor}" CornerRadius="6">
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource SecondaryBlueColor}" Text="{Binding Operation.OperationType, Converter={StaticResource OperationTypeToLabelConverter}}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextColor}" Text="{Binding Name}" />
                                                <StackPanel Margin="0,2,0,2" Orientation="Horizontal">
                                                    <Ellipse Width="7" Height="7" Margin="0,0,5,0" VerticalAlignment="Center" Style="{StaticResource EnabledStateDotStyle}" />
                                                    <TextBlock VerticalAlignment="Center" Style="{StaticResource EnabledStateTextStyle}" />
                                                </StackPanel>
                                                <TextBlock FontSize="11" Foreground="{DynamicResource PrimaryGrayColor}" Text="{Binding Description}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <Button Grid.Column="2" Width="24" Height="24" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Command="{Binding DataContext.RemoveOperationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Content="" Cursor="Hand" Style="{StaticResource DeleteButtonStyle}" ToolTip="Remove operation" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                </Grid>
            </Grid>
            <TextBlock Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource PrimaryGrayColor}" Text="Select a step to view its operations">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedStep}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <Border Grid.Column="3" Background="LightGray" />
            <!-- RIGHT: Operation editor -->
            <Grid Grid.Column="4">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource PrimaryGrayColor}" Text="Select an operation to edit">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedOperation}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedOperation}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource PanelHeaderBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Margin="0,0,10,0" Style="{StaticResource PanelHeaderTitleStyle}" Text="Operation" />
                                <StackPanel Grid.Column="1" Margin="0,0,2,0" VerticalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource PrimaryTextColor}" Text="{Binding SelectedOperation.Enabled, Converter={StaticResource BoolToEnabledDisabledTextConverter}}" />
                                    <ToggleButton IsChecked="{Binding SelectedOperation.Enabled, Mode=TwoWay}" Style="{StaticResource ToggleButtonStyle}" />
                                </StackPanel>
                        </Grid>
                    </Border>
                    <ContentControl Grid.Row="1" Content="{Binding SelectedOperation}" ContentTemplateSelector="{StaticResource OperationEditorTemplateSelector}" />
                </Grid>
            </Grid>
        </Grid>
        <!--  End Main Content Grid  -->
    </Grid>
</UserControl>
