<UserControl
    x:Class="ServerMultiTool.Shared.Components.ProfileEditor.EditPipelineProfileControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:ServerMultiTool.ViewModels.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:editPipelineProfile="clr-namespace:ServerMultiTool.Shared.Components.ProfileEditor"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    MinHeight="520"
    d:DataContext="{d:DesignInstance Type=editPipelineProfile:EditPipelineProfileViewModel, IsDesignTimeCreatable=True}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToEnabledDisabledTextConverter x:Key="BoolToEnabledDisabledTextConverter" />
        <converters:IncrementConverter x:Key="IncrementConverter" />
        <converters:OperationTypeToLabelConverter x:Key="OperationTypeToLabelConverter" />
        <converters:DeliveryDirectoryConverter x:Key="DeliveryDirectoryConverter" />
        <converters:ObjectEqualityConverter x:Key="ObjectEqualityConverter" />
        <converters:ItemIndexConverter x:Key="ItemIndexConverter" />
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryGrayColor}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="FieldTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}" />
            <Setter Property="Background" Value="{DynamicResource TertiaryBackgroundColor}" />
            <Setter Property="BorderBrush" Value="LightGray" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="BrowseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="{DynamicResource TertiaryBackgroundColor}" />
            <Setter Property="BorderBrush" Value="LightGray" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <Path Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z" Fill="{DynamicResource PrimaryGrayColor}" Stretch="Uniform" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryWhiteColor}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SectionExpanderStyle" TargetType="Expander">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="IsExpanded" Value="True" />
        </Style>
        <Style x:Key="SmallAddButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource TertiaryBackgroundColor}" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryBlueColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SecondaryBlueColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{TemplateBinding FontSize}" Foreground="{TemplateBinding Foreground}" Text="{TemplateBinding Content}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryWhiteColor}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryRedColor}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center" Data="M9,3V4H4V6H5V19A2,2 0 0,0 7,21H17A2,2 0 0,0 19,19V6H20V4H15V3H9M7,6H17V19H7V6M9,8V17H11V8H9M13,8V17H15V8H13Z" Fill="{DynamicResource PrimaryRedColor}" Stretch="Uniform" />
                            <TextBlock VerticalAlignment="Center" FontSize="{TemplateBinding FontSize}" Foreground="{DynamicResource PrimaryRedColor}" Text="{TemplateBinding Content}" />
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PanelHeaderBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundColor}" />
            <Setter Property="BorderBrush" Value="LightGray" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
        <Style x:Key="PanelHeaderTitleStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}" />
        </Style>
        <Style x:Key="EnabledStateTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryGreenColor}" />
            <Setter Property="Text" Value="Enabled" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Enabled}" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource DisabledTextColor}" />
                    <Setter Property="Text" Value="Disable" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="EnabledStateDotStyle" TargetType="Ellipse">
            <Setter Property="Fill" Value="{DynamicResource PrimaryGreenColor}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Enabled}" Value="False">
                    <Setter Property="Fill" Value="{DynamicResource DisabledBorderColor}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!-- ProcessExecution editor -->
        <DataTemplate x:Key="ProcessExecutionEditorTemplate">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="14,10">
                    <Expander Header="General" IsExpanded="{Binding DataContext.IsOperationGeneralExpanded, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" Style="{StaticResource SectionExpanderStyle}">
                        <StackPanel Margin="2,8,2,8">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Name" />
                            <TextBox Margin="0,0,0,10" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Description" />
                                    <TextBox Style="{StaticResource FieldTextBoxStyle}" Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Expander>
                    <Expander Header="Command" Style="{StaticResource SectionExpanderStyle}">
                        <StackPanel Margin="2,8,2,8">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="File Name" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Margin="0,0,4,0" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding FileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="1" Command="{Binding DataContext.BrowseOperationFileNameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" Style="{StaticResource BrowseButtonStyle}" />
                            </Grid>
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Arguments" />
                            <TextBox Margin="0,0,0,10" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding Arguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Retry Count" />
                            <TextBox Width="100" HorizontalAlignment="Left" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding RetryCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Expander>
                    <Border Margin="0,6,0,0" Padding="8,6" Background="#FFF8E7" BorderBrush="#FFE082" BorderThickness="1" CornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center" Data="{StaticResource Information}" Fill="#F5A623" Stretch="Uniform" />
                            <StackPanel>
                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#8A6000" Text="Tip" />
                                <TextBlock FontSize="11" Foreground="#8A6000" Text="Changes are saved automatically" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>
        <!-- DeliverySpecifiedFiles editor -->
        <DataTemplate x:Key="DeliverySpecifiedFilesEditorTemplate">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="14,10">
                    <Expander Header="General" IsExpanded="{Binding DataContext.IsOperationGeneralExpanded, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" Style="{StaticResource SectionExpanderStyle}">
                        <StackPanel Margin="2,8,2,8">
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Name" />
                            <TextBox Margin="0,0,0,10" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Description" />
                                    <TextBox Style="{StaticResource FieldTextBoxStyle}" Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Expander>
                    <TextBlock Margin="0,0,0,6" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextColor}" Text="Delivery Directories" />
                    <ItemsControl ItemsSource="{Binding Directories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,4,0,0" Padding="10,8" Background="{DynamicResource SecondaryBackgroundColor}" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Source" />
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Margin="0,0,4,0" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding Source, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Grid.Column="1" Command="{Binding DataContext.BrowseDeliverySourceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource BrowseButtonStyle}" />
                                        </Grid>
                                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Destination" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Margin="0,0,4,0" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding Destination, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Grid.Column="1" Command="{Binding DataContext.BrowseDeliveryDestinationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource BrowseButtonStyle}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border Margin="0,10,0,0" Padding="8,6" Background="#FFF8E7" BorderBrush="#FFE082" BorderThickness="1" CornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center" Data="{StaticResource Information}" Fill="#F5A623" Stretch="Uniform" />
                            <StackPanel>
                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#8A6000" Text="Tip" />
                                <TextBlock FontSize="11" Foreground="#8A6000" Text="Changes are saved automatically" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>
        <!-- MsBuild editor -->
