                            <TextBox Margin="0,0,0,10" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding Directory.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Relative Path" />
                            <TextBox Margin="0,0,0,10" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding Directory.Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Style="{StaticResource SectionLabelStyle}" Text="Retry Count" />
                            <TextBox Width="100" HorizontalAlignment="Left" Style="{StaticResource FieldTextBoxStyle}" Text="{Binding RetryCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Expander>
                    <Border Margin="0,6,0,0" Padding="8,6" Background="#FFF8E7" BorderBrush="#FFE082" BorderThickness="1" CornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center" Data="{StaticResource Information}" Fill="#F5A623" Stretch="Uniform" />
                            <StackPanel>
                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#8A6000" Text="Tip" />
                                <TextBlock FontSize="11" Foreground="#8A6000" Text="Changes are saved automatically" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>
