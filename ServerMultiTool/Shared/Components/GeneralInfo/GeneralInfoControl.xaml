<UserControl
    x:Class="ServerMultiTool.Shared.Components.GeneralInfo.GeneralInfoControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <!--  d:DataContext="{d:DesignInstance Type=controls:GeneralInfoViewModel, IsDesignTimeCreatable=True}"  -->

    <Grid Background="{DynamicResource SecondaryBackgroundColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid
            Grid.Row="0"
            Grid.Column="0"
            Margin="0,5,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                HorizontalAlignment="Right"
                Style="{DynamicResource CustomTextBlockStyle}"
                Text="Solution:" />
            <ComboBox
                Grid.Column="1"
                Width="200"
                Height="30"
                Margin="10,0,0,0"
                DisplayMemberPath="Name"
                IsEnabled="{Binding CanChangeStates}"
                ItemsSource="{Binding SolutionDirectories, Mode=TwoWay}"
                SelectedItem="{Binding SelectedSolutionDirectory, Mode=TwoWay}"
                Style="{DynamicResource ComboBoxStyle}" />
        </Grid>

        <Grid
            Grid.Row="0"
            Grid.Column="1"
            Margin="50,5,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Viewbox
                Grid.Column="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <Path Data="{DynamicResource Branch}" Fill="{DynamicResource PrimaryTextColor}" />
            </Viewbox>
            <Label
                Grid.Column="1"
                Height="30"
                Margin="10,5,0,5"
                HorizontalContentAlignment="Left"
                VerticalContentAlignment="Center"
                Background="{DynamicResource TertiaryBackgroundColor}"
                Content="{Binding CurrentGitBranch, Mode=OneWay}"
                FontSize="14"
                Foreground="{DynamicResource SecondaryTextColor}" />
        </Grid>

        <Grid
            Grid.Row="1"
            Grid.Column="0"
            Margin="0,5,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                HorizontalAlignment="Right"
                Style="{DynamicResource CustomTextBlockStyle}"
                Text="Http Directory:" />
            <ComboBox
                Grid.Column="1"
                Width="200"
                Height="30"
                Margin="10,0,0,0"
                DisplayMemberPath="Name"
                IsEnabled="{Binding CanChangeStates}"
                ItemsSource="{Binding HttpDirectories, Mode=TwoWay}"
                SelectedItem="{Binding SelectedHttpDirectory, Mode=TwoWay}"
                Style="{DynamicResource ComboBoxStyle}" />
        </Grid>
    </Grid>
</UserControl>

