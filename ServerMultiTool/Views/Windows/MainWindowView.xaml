
<Window x:Class="ServerMultiTool.Views.Windows.MainWindowView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" 
        xmlns:windows="clr-namespace:ServerMultiTool.ViewModels.Windows"
        MinHeight="600" 
        MinWidth="900"
        Height="800"
        Width="1200"
        WindowStartupLocation="CenterScreen" 
        WindowState="Normal" 
        FontFamily="Poppins"
        Icon="/Views/Assets/Icons/plarium-logo.png"
        d:DataContext="{d:DesignInstance Type=windows:MainWindowViewModel, IsDesignTimeCreatable=True}">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" 
                      ResizeBorderThickness="5" 
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid Background="{DynamicResource PrimaryBackgroundColor}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Start: Top Bar -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
        Background="{DynamicResource SecondaryBackgroundColor}"
        CornerRadius="0,10,0,0"
        MouseLeftButtonDown="DragArea_MouseLeftButtonDown"
        MouseMove="DragArea_MouseMove"
        MouseLeftButtonUp="DragArea_MouseLeftButtonUp">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo and Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,10,0,0">
                    <Path Data="{DynamicResource Plarium}" 
                  Stretch="Fill" 
                          Width="28" Height="28"   
                  Fill="{DynamicResource PrimaryTextColor}" 
                  VerticalAlignment="Center"
                  Margin="10 0 10 0"/>
                    <Label Content="Raid GS Tools"
                   Foreground="{DynamicResource PrimaryTextColor}" 
                   FontFamily="Segoe UI Semibold"
                   FontSize="20"
                   VerticalContentAlignment="Center"
                   Padding="0" />
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,5,10,0" FlowDirection="RightToLeft">
                    <Button Style="{StaticResource IconButtonsStyle}" 
                    Content="{DynamicResource Close}" 
                    Command="{Binding CloseCommand}" 
                    Tag="IsCloseButton"/>
                    <Button Margin="5 0" Command="{Binding RestoreCommand}">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource IconButtonsStyle}">
                                <Setter Property="Content" Value="{DynamicResource Maximize}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}, Path=WindowState}" Value="Maximized">
                                        <Setter Property="Content" Value="{DynamicResource Restore}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Style="{DynamicResource IconButtonsStyle}" 
                    Content="{DynamicResource Minimize}" 
                    Command="{Binding MinimizeCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
        <!-- End: Top Bar -->

        <!-- Start: GridColumn Left -->
        <Border Grid.Column="0" Grid.Row="1"
                Padding="10"
                Background="{DynamicResource SecondaryBackgroundColor}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="130"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <!-- Start:  Menu -->
                <StackPanel Grid.Row="0" Margin="0 30 0 30" >
                    <RadioButton Content="CI/CD Pipeline" 
                                 Style="{DynamicResource MenuRadioButtonStyle}" 
                                 Tag="{DynamicResource Airplane}" 
                                 Command="{Binding NavigateCommand}" 
                                 CommandParameter="Pipeline"/>
                    <RadioButton Content="Json Parser" 
                                 Style="{DynamicResource MenuRadioButtonStyle}" 
                                 Tag="{DynamicResource Json}" 
                                 Command="{Binding NavigateCommand}" 
                                 CommandParameter="JsonParser"/>
                    <Separator Margin="20 20" Background="{DynamicResource TertiaryBackgroundColor}"/>
                    <RadioButton Content="Notifications" 
                                 Style="{DynamicResource MenuRadioButtonStyle}" 
                                 Tag="{DynamicResource Notifications}"
                                 Command="{Binding NavigateCommand}" 
                                 CommandParameter="Notifications"/>
                    <RadioButton Content="Settings" 
                                 Style="{DynamicResource MenuRadioButtonStyle}" 
                                 Tag="{DynamicResource Settings}" 
                                 Command="{Binding NavigateCommand}" 
                                 CommandParameter="Settings"/>
                </StackPanel>
                <!-- End:  Menu -->

                <!-- Start:  Theme -->
                <Border Grid.Row="3" 
                        CornerRadius="18" 
                        Width="110" Height="35" 
                        Background="{DynamicResource TertiaryBackgroundColor}" 
                        HorizontalAlignment="Left" 
                        Margin="20 0 20 0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Path Data="{DynamicResource Sun}" 
                              Height="16" Width="16" 
                              Stretch="UniformToFill" 
                              Fill="{DynamicResource PrimaryYellowColor}" 
                              VerticalAlignment="Center"/>
                        <ToggleButton x:Name="Themes"
                              IsChecked="False"
                              Command="{Binding ChangeThemeCommand}"
                              HorizontalAlignment="Right"
                              Style="{DynamicResource ToggleButtonStyle}"
                              Margin="10 0 10 0"/>
                        <Path Data="{DynamicResource Moon}" 
                              Height="16" Width="16" Stretch="Fill" 
                              Fill="{DynamicResource PrimaryWhiteColor}" 
                              VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border.BitmapEffect>
                        <DropShadowBitmapEffect
                                        ShadowDepth="1"
                                        Direction="0"
                                        Color="#5B8DEF"
                                        Softness="0.8"/>
                    </Border.BitmapEffect>
                </Border>
                <!-- End:  Theme -->
            </Grid>
        </Border>


        <!-- Start: Frame Container -->
        <Border Grid.Column="1" Grid.Row="1"  Background="Transparent">
            <Frame NavigationUIVisibility="Hidden" 
                       Content="{Binding CurrentPage}" 
                       Margin="10"/>
        </Border>
        <!-- End: Frame Container -->
        <!-- End: GridColumn Left -->
    </Grid>
</Window>