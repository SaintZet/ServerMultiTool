<Window x:Class="ServerMultiTool.Views.Windows.MainWindowView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" 
        xmlns:windows="clr-namespace:ServerMultiTool.ViewModels.Windows"
        MinHeight="600" 
        MinWidth="900"
        Height="800"
        Width="1200"
        WindowStartupLocation="CenterScreen" 
        WindowState="Normal" 
        FontFamily="Poppins"
        Icon="/Views/Assets/Icons/plarium-logo.png"
        d:DataContext="{d:DesignInstance Type=windows:MainWindowViewModel, IsDesignTimeCreatable=True}">
    
    <Grid Background="{DynamicResource PrimaryBackgroundColor}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" MinWidth="180" MaxWidth="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Start: GridColumn Left -->
        <Border Grid.Column="0"
                Padding="10"
                Background="{DynamicResource SecondaryBackgroundColor}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" MinHeight="40"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto" MinHeight="100" MaxHeight="150"/>
                    <RowDefinition Height="Auto" MinHeight="60" MaxHeight="100"/>
                </Grid.RowDefinitions>
                
                <!-- Start:  Logo -->
                <Border Grid.Row="0">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{DynamicResource Plarium}" 
                              Stretch="Uniform" 
                              Fill="{DynamicResource PrimaryTextColor}" 
                              VerticalAlignment="Center"
                              Width="24" Height="24"
                              Margin="10 0 0 6"/>
                        <Label Content="Raid GS Tools"
                               Foreground="{DynamicResource PrimaryTextColor}" 
                               FontFamily="Segoe UI Italic"
                               FontSize="16" 
                               VerticalContentAlignment="Center"  
                               HorizontalContentAlignment="Left" 
                               HorizontalAlignment="Left" 
                               Padding="0,0,0,0" 
                               Margin="10 0 0 0"/>
                    </StackPanel>
                </Border>
                <!-- End:  Logo -->
                
                <!-- Start:  Menu -->
                <StackPanel Grid.Row="1" Margin="0 20 0 20" >
                    <RadioButton Content="CI/CD Pipeline" 
                                 Style="{DynamicResource MenuRadioButtonStyle}" 
                                 Tag="{DynamicResource Airplane}" 
                                 Command="{Binding NavigateCommand}" 
                                 CommandParameter="Pipeline"/>
                    <RadioButton Content="Json Parser" 
                                 Style="{DynamicResource MenuRadioButtonStyle}" 
                                 Tag="{DynamicResource Json}" 
                                 Command="{Binding NavigateCommand}" 
                                 CommandParameter="JsonParser"/>
                    <Separator Margin="15 15" Background="{DynamicResource TertiaryBackgroundColor}"/>
                    <RadioButton Content="Notifications" 
                                 Style="{DynamicResource MenuRadioButtonStyle}" 
                                 Tag="{DynamicResource Notifications}"
                                 Command="{Binding NavigateCommand}" 
                                 CommandParameter="Notifications"/>
                    <RadioButton Content="Settings" 
                                 Style="{DynamicResource MenuRadioButtonStyle}" 
                                 Tag="{DynamicResource Settings}" 
                                 Command="{Binding NavigateCommand}" 
                                 CommandParameter="Settings"/>
                </StackPanel>
                <!-- End:  Menu -->
                
                <!-- Start:  Theme -->
                <Border Grid.Row="3" 
                        CornerRadius="18" 
                        MinWidth="100" MaxWidth="130"
                        Height="35" 
                        Background="{DynamicResource TertiaryBackgroundColor}" 
                        HorizontalAlignment="Center" 
                        Margin="10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Path Data="{DynamicResource Sun}" 
                              Height="16" Width="16" 
                              Stretch="UniformToFill" 
                              Fill="{DynamicResource PrimaryYellowColor}" 
                              VerticalAlignment="Center"/>
                        <ToggleButton x:Name="Themes"
                              IsChecked="False"
                              Command="{Binding ChangeThemeCommand}"
                              HorizontalAlignment="Right"
                              Style="{DynamicResource ToggleButtonStyle}"
                              Margin="10 0 10 0"/>
                        <Path Data="{DynamicResource Moon}" 
                              Height="16" Width="16" Stretch="Fill" 
                              Fill="{DynamicResource PrimaryWhiteColor}" 
                              VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border.BitmapEffect>
                        <DropShadowBitmapEffect
                                        ShadowDepth="1"
                                        Direction="0"
                                        Color="#5B8DEF"
                                        Softness="0.8"/>
                    </Border.BitmapEffect>
                </Border>
                <!-- End:  Theme -->
            </Grid>
        </Border>
        <!-- End: GridColumn Left -->

        <!-- Start: GridColumn Right -->
        <Grid Grid.Column="1" Background="{DynamicResource PrimaryBackgroundColor}">
            <!-- Start: Frame Container -->
            <Frame NavigationUIVisibility="Hidden" 
                   Content="{Binding CurrentPage}" 
                   Margin="10"/>
            <!-- End: Frame Container -->
        </Grid>
        <!-- End: GridColumn Right -->
    </Grid>
    
</Window>