
<Page x:Class="ServerMultiTool.Views.Pages.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:ServerMultiTool.Views.Controls"
      xmlns:settings="clr-namespace:ServerMultiTool.ViewModels.Pages.Settings"
      mc:Ignorable="d" 
      d:DesignHeight="750" d:DesignWidth="700"
      Title="Settings" 
      FontFamily="Poppins">
      <!--d:DataContext="{d:DesignInstance Type=settings:SettingsViewModel, IsDesignTimeCreatable=True}"-->
      
    
    <Border CornerRadius="8" Background="{DynamicResource SecondaryBackgroundColor}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <controls:GeneralInfoControl Grid.Row="0"  
                                        Margin="10"  
                                        DataContext="{Binding GeneralInfo}"/>
            
            <TabControl Grid.Row="1"  
                        Margin="10,10,10,0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border Name="Border" 
                                            BorderThickness="1,1,1,0" 
                                            BorderBrush="Gainsboro" 
                                            CornerRadius="4,4,0,0" 
                                            Margin="2,0,2,-1"
                                            Padding="0,0,0,2">
                                        <ContentPresenter x:Name="ContentSite"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"
                                                          ContentSource="Header"
                                                          Margin="10,2"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Panel.ZIndex" Value="1"/>
                                            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextColor}"/>
                                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource TertiaryBackgroundColor}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}"/>
                                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource SecondaryBackgroundColor}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>
                
                <!-- Main Settings Tab -->
                <TabItem Header="Main Settings">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Border BorderThickness="0.8" BorderBrush="Gainsboro" Padding="10">
                            <StackPanel>
                                <!-- Solution Directories -->
                                <DockPanel Margin="0,0,0,20">
                                    <Label DockPanel.Dock="Top"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextColor}"
                                           Content="Solution Directories:" 
                                           Margin="0,0,0,5"/>
                                    
                                    <StackPanel DockPanel.Dock="Bottom"
                                                Orientation="Horizontal" 
                                                HorizontalAlignment="Left" 
                                                Margin="0,5,0,0">
                                        <Button Content="Add" 
                                                Command="{Binding AddSolutionDirectoryCommand}" 
                                                Style="{StaticResource CustomButtonStyle}"
                                                MinWidth="60"
                                                Height="30"
                                                Margin="0,0,5,0"/>
                                        <Button Content="Delete" 
                                                Style="{StaticResource CustomButtonStyle}"
                                                Command="{Binding RemoveSolutionDirectoryCommand}"
                                                CommandParameter="{Binding SelectedSolutionDirectory}"
                                                MinWidth="60"
                                                Height="30"/>
                                    </StackPanel>
                                    
                                    <ListBox ItemsSource="{Binding SolutionDirectories}" 
                                             SelectedItem="{Binding SelectedSolutionDirectory}" 
                                             Background="{DynamicResource TertiaryBackgroundColor}"
                                             Foreground="{DynamicResource PrimaryTextColor}"
                                             MinHeight="120"
                                             MaxHeight="250"
                                             Padding="5"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Vertical" Margin="0,5">
                                                    <TextBox Text="{Binding Name}" 
                                                             FontWeight="Bold" 
                                                             Margin="0,0,0,5"
                                                             Background="Transparent"
                                                             Foreground="{DynamicResource PrimaryTextColor}"
                                                             BorderThickness="0"/>
                                                    <DockPanel>
                                                        <Button DockPanel.Dock="Right"
                                                                Content="..." 
                                                                Command="{Binding DataContext.SelectDirectoryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                CommandParameter="{Binding}" 
                                                                Width="25" 
                                                                Height="25" 
                                                                Margin="5,0,0,0"/>
                                                        <TextBlock Text="{Binding Path}" 
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource SecondaryTextColor}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap"/>
                                                    </DockPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                                
                                <!-- HTTP Directories -->
                                <DockPanel>
                                    <Label DockPanel.Dock="Top"
                                           Content="Http Directories:" 
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextColor}"
                                           Margin="0,0,0,5"/>
                                    
                                    <StackPanel DockPanel.Dock="Bottom"
                                                Orientation="Horizontal" 
                                                HorizontalAlignment="Left" 
                                                Margin="0,5,0,0">
                                        <Button Content="Add" 
                                                Command="{Binding AddHttpDirectoryCommand}" 
                                                Style="{StaticResource CustomButtonStyle}"
                                                MinWidth="60"
                                                Height="30"
                                                Margin="0,0,5,0"/>
                                        <Button Content="Delete" 
                                                Command="{Binding RemoveHttpDirectoryCommand}"
                                                CommandParameter="{Binding SelectedHttpDirectory}"
                                                Style="{StaticResource CustomButtonStyle}"
                                                MinWidth="60"
                                                Height="30"/>
                                    </StackPanel>
                                    
                                    <ListBox ItemsSource="{Binding HttpDirectories}" 
                                             SelectedItem="{Binding SelectedHttpDirectory}" 
                                             Background="{DynamicResource TertiaryBackgroundColor}"
                                             Foreground="{DynamicResource PrimaryTextColor}"
                                             MinHeight="150"
                                             MaxHeight="250"
                                             Padding="5"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Vertical" Margin="0,5">
                                                    <TextBox Text="{Binding Name}" 
                                                             FontWeight="Bold" 
                                                             Margin="0,0,0,5"
                                                             Background="Transparent"
                                                             Foreground="{DynamicResource PrimaryTextColor}"
                                                             BorderThickness="0"/>
                                                    <DockPanel>
                                                        <Button DockPanel.Dock="Right"
                                                                Content="..." 
                                                                Command="{Binding DataContext.SelectDirectoryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                CommandParameter="{Binding}" 
                                                                Width="25" 
                                                                Height="25" 
                                                                Margin="5,0,0,0"/>
                                                        <TextBlock Text="{Binding Path}" 
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource SecondaryTextColor}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap"/>
                                                    </DockPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </TabItem>
                
                <!-- Pipeline Profiles Tab -->
                <TabItem Header="Pipeline Profiles">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Border BorderThickness="0.8" BorderBrush="Gainsboro" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" MinHeight="200"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Pipeline Profiles List -->
                                <DockPanel Grid.Row="0" Margin="0,0,0,20">

                                    <StackPanel DockPanel.Dock="Bottom"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Left"
                                                Margin="0,5,0,0">
                                        <Button Content="Add"
                                                Command="{Binding AddPipelineProfileCommand}"
                                                Style="{StaticResource CustomButtonStyle}"
                                                MinWidth="60"
                                                Height="30"
                                                Margin="0,0,5,0"/>
                                        <Button Content="Delete"
                                                Command="{Binding RemovePipelineProfileCommand}"
                                                CommandParameter="{Binding SelectedPipelineProfile}"
                                                Style="{StaticResource CustomButtonStyle}"
                                                MinWidth="60"
                                                Height="30"/>
                                    </StackPanel>
                                    
                                    <ListBox ItemsSource="{Binding PipelineProfiles}"
                                             SelectedItem="{Binding SelectedPipelineProfile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             IsSynchronizedWithCurrentItem="True"
                                             Background="{DynamicResource TertiaryBackgroundColor}"
                                             Foreground="{DynamicResource PrimaryTextColor}"
                                             MinHeight="150"
                                             MaxHeight="250"
                                             Padding="5"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Vertical" Margin="0,5">
                                                    <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             FontWeight="Bold"
                                                             FontSize="13"
                                                             Margin="0,0,0,5"
                                                             Background="Transparent"
                                                             Foreground="{DynamicResource PrimaryTextColor}"
                                                             BorderThickness="0"/>
                                                    <ScrollViewer MaxHeight="40" 
                                                                  VerticalScrollBarVisibility="Auto"
                                                                  HorizontalScrollBarVisibility="Disabled">
                                                        <ItemsControl ItemsSource="{Binding Operations}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding DisplayName}"
                                                                               Foreground="{DynamicResource SecondaryTextColor}"
                                                                               Margin="10,2,0,0"
                                                                               TextWrapping="Wrap"/>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                </DockPanel>
                                
                                <!-- Profile Editor -->
                                <DockPanel Grid.Row="1">
                                    <Label DockPanel.Dock="Top"
                                           Content="Edit Pipeline Profile"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Foreground="{DynamicResource PrimaryTextColor}"
                                           Margin="0,0,0,5"/>

                                    
                                    <Border BorderThickness="1"
                                            BorderBrush="LightGray"
                                            CornerRadius="5"
                                            Padding="5"
                                            Background="{DynamicResource TertiaryBackgroundColor}">
                                        
                                        <Grid>
                                            <!-- Message when profile is not selected -->
                                            <TextBlock Text="Select a profile to edit its settings"
                                                       Foreground="{DynamicResource SecondaryTextColor}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedPipelineProfile}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            
                                            <!-- Profile Edit Settings -->
                                            <controls:EditPipelineProfileControl DataContext="{Binding EditPipelineProfile}">
                                                <controls:EditPipelineProfileControl.Style>
                                                    <Style TargetType="controls:EditPipelineProfileControl">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DataContext.SelectedPipelineProfile, RelativeSource={RelativeSource AncestorType=Grid}}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </controls:EditPipelineProfileControl.Style>
                                            </controls:EditPipelineProfileControl>
                                        </Grid>
                                    </Border>
                                </DockPanel>
                            </Grid>
                        </Border>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
            
            <!-- Save/Cancel buttons -->
            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        Margin="10">
                <Button Content="Cancel" 
                        Command="{Binding CancelSettingsCommand}" 
                        IsEnabled="{Binding HasUnsavedChanges}"
                        Style="{StaticResource CustomButtonStyle}"
                        MinWidth="70"
                        Height="35"
                        Margin="0,0,10,0"/>
                <Button Content="Save" 
                        Command="{Binding SaveSettingsCommand}"
                        IsEnabled="{Binding HasUnsavedChanges}"
                        Style="{StaticResource CustomButtonStyle}"
                        MinWidth="70"
                        Height="35"/>
            </StackPanel>
        </Grid>
    </Border>
</Page>