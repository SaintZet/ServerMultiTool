<Page
    x:Class="ServerMultiTool.Views.Pages.JsonParserView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ServerMultiTool.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:jsonParser="clr-namespace:ServerMultiTool.ViewModels.Features.JsonParser"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{Binding Title}"
    d:DataContext="{d:DesignInstance Type=jsonParser:JsonParserViewModel, IsDesignTimeCreatable=True}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    FontFamily="Poppins"
    mc:Ignorable="d">

    <Border Background="{DynamicResource SecondaryBackgroundColor}" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <controls:GeneralInfoControl
                Grid.Row="0"
                Margin="10"
                DataContext="{Binding GeneralInfo}" />

            <Border
                Grid.Row="1"
                Background="{DynamicResource SecondaryBackgroundColor}"
                CornerRadius="8">
                <Label
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Content="TODO"
                    FontSize="50"
                    FontWeight="Bold"
                    Foreground="{DynamicResource PrimaryTextColor}" />
            </Border>
        </Grid>
    </Border>
</Page>
