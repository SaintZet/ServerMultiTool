<UserControl x:Class="ServerMultiTool.Views.Controls.EditPipelineProfileControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:editPipelineProfile="clr-namespace:ServerMultiTool.ViewModels.Controls.EditPipelineProfile"
             xmlns:converters1="clr-namespace:ServerMultiTool.ViewModels.Controls.EditPipelineProfile.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=editPipelineProfile:EditPipelineProfileViewModel, IsDesignTimeCreatable=True}">
    
    <UserControl.Resources>
        <converters1:ProcessEventConverter x:Key="ProcessEventConverter"/>
        <converters1:DeliveryDirectoryConverter x:Key="DeliveryDirectoryConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <!-- Global settings with Expanders -->
            <TextBlock Text="Global Settings:"
                      Margin="0,0,0,10"
                      FontWeight="Bold"
                      FontSize="14"
                      Foreground="{DynamicResource PrimaryTextColor}"/>

            <!-- Git Settings -->
            <Expander Header="Git Settings" Margin="0,0,0,5">
                <StackPanel Margin="20,5">
                    <CheckBox Content="Enable Git" 
                             IsChecked="{Binding Profile.GitSettings.Enable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             Foreground="{DynamicResource PrimaryTextColor}"/>
                    
                    <CheckBox Content="Should Pull" 
                             IsChecked="{Binding Profile.GitSettings.ShouldPull, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,5"
                             Foreground="{DynamicResource PrimaryTextColor}"/>
                </StackPanel>
            </Expander>

            <!-- IIS Settings -->
            <Expander Header="IIS Settings" Margin="0,0,0,5">
                <StackPanel Margin="20,5">
                    <CheckBox Content="Enable IIS Restart" 
                             IsChecked="{Binding Profile.InternetInformationSettings.Enable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             Foreground="{DynamicResource PrimaryTextColor}"/>
                </StackPanel>
            </Expander>

            <!-- SQL Settings -->
            <Expander Header="SQL Settings" Margin="0,0,0,5">
                <StackPanel Margin="20,5">
                    <CheckBox Content="Enable SQL Execution" 
                             IsChecked="{Binding Profile.SqlExecutionSettings.Enable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             Foreground="{DynamicResource PrimaryTextColor}"/>
                    <TextBlock Text="Connection String:" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Profile.SqlExecutionSettings.ConnectionString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             Height="25" 
                             Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Path to SQL script:" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Profile.SqlExecutionSettings.PathToSqlScript, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             Height="25" 
                             Margin="0,0,0,10"/>

                </StackPanel>
            </Expander>

            <!-- Web Browser Settings -->
            <Expander Header="Web Browser Settings" Margin="0,0,0,5">
                <StackPanel Margin="20,5">
                    <CheckBox Content="Enable open window in Web Browser" 
                             IsChecked="{Binding Profile.WebBrowserSettings.Enable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             Foreground="{DynamicResource PrimaryTextColor}"/>
                    
                    <TextBlock Text="URL:" Margin="0,0,0,5" Foreground="{DynamicResource PrimaryTextColor}"/>
                    <TextBox Text="{Binding Profile.WebBrowserSettings.Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             Height="25" 
                             Margin="0,0,0,10"/>
                </StackPanel>
            </Expander>

            <!-- HTTP Monitoring Settings -->
            <Expander Header="HTTP Monitoring Settings" Margin="0,0,0,5">
                <StackPanel Margin="20,5">
                    <CheckBox Content="Enable HTTP Monitoring" 
                             IsChecked="{Binding Profile.HttpMonitoringSettings.Enable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             Foreground="{DynamicResource PrimaryTextColor}"/>
                    
                    <CheckBox Content="Ping Segment" 
                             IsChecked="{Binding Profile.HttpMonitoringSettings.PingSegment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,5"
                             Foreground="{DynamicResource PrimaryTextColor}"/>
                    
                    <CheckBox Content="Ping Master" 
                             IsChecked="{Binding Profile.HttpMonitoringSettings.PingMaster, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             Foreground="{DynamicResource PrimaryTextColor}"/>
                    
                    <TextBlock Text="Timeout (Minutes):" Margin="0,0,0,5" Foreground="{DynamicResource PrimaryTextColor}"/>
                    <TextBox Text="{Binding Profile.HttpMonitoringSettings.TimeoutMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             Height="25" 
                             Margin="0,0,0,10"/>
                </StackPanel>
            </Expander>

            <!-- Monitor Log Files Settings -->
            <Expander Header="Log Files Monitoring Settings" Margin="0,0,0,5">
                <StackPanel Margin="20,5">
                    <CheckBox Content="Enable Log Files Monitoring" 
                             IsChecked="{Binding Profile.MonitorLogFilesSettings.Enable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             Foreground="{DynamicResource PrimaryTextColor}"/>
                    
                    <TextBlock Text="Log Directory Name:" Margin="0,0,0,5" Foreground="{DynamicResource PrimaryTextColor}"/>
                    <TextBox Text="{Binding Profile.MonitorLogFilesSettings.LogDirectory.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             Height="25" 
                             Margin="0,0,0,5"/>
                    
                    <TextBlock Text="Log Directory Path:" Margin="0,0,0,5" Foreground="{DynamicResource PrimaryTextColor}"/>
                    <TextBox Text="{Binding Profile.MonitorLogFilesSettings.LogDirectory.Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             Height="25" 
                             Margin="0,0,0,10"/>
                </StackPanel>
            </Expander>

            <!-- Settings Per Project -->
            <StackPanel Margin="0,20,0,0">
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Settings Per Project:"
                             Margin="0,0,10,0"
                             FontWeight="Bold"
                             FontSize="14"
                             Foreground="{DynamicResource PrimaryTextColor}"/>
                    <Button Content="Add Project"
                            Command="{Binding AddProjectCommand}"
                            Style="{StaticResource CustomButtonStyle}"
                            HorizontalAlignment="Right"
                            Width="100"
                            Height="25"/>
                </DockPanel>

                <ItemsControl ItemsSource="{Binding ProjectSettings}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SecondaryBackgroundColor}"
                                    Margin="0,0,0,10"
                                    Padding="10"
                                    CornerRadius="5">
                                <StackPanel>
                                    <!-- Project Info -->
                                    <DockPanel Margin="0,0,0,10">
                                        <Button Content="Remove"
                                                Command="{Binding DataContext.RemoveProjectCommand, 
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource CustomButtonStyle}"
                                                DockPanel.Dock="Right"
                                                Width="70"
                                                Height="25"/>
                                        
                                        <StackPanel>
                                            <DockPanel Margin="0,0,10,5">
                                                <TextBlock Text="Name:" Width="50"/>
                                                <TextBox Text="{Binding ProjectName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="25"/>
                                            </DockPanel>
                                            <DockPanel Margin="0,0,10,0">
                                                <TextBlock Text="Path:" Width="50"/>
                                                <TextBox Text="{Binding ProjectPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="25"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- MSBuild Settings -->
                                    <Expander Header="Build Settings" Margin="0,0,0,5">
                                        <StackPanel Margin="20,5">
                                            <CheckBox Content="Enable MSBuild" 
                                                      IsChecked="{Binding MsBuildEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Margin="0,0,0,5"/>

                                            <TextBlock Text="Build Parameters:" Margin="0,5"/>
                                            <ItemsControl ItemsSource="{Binding BuildParameters}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding Path=., Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                                 Margin="0,2"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                                <TextBox x:Name="ParameterTextBox"
                                                         Width="200"
                                                         Height="25"
                                                         Margin="0,0,10,0"
                                                         VerticalContentAlignment="Center"/>
    
                                                <Button Content="Add"
                                                        Command="{Binding AddBuildParameterCommand}"
                                                        CommandParameter="{Binding ElementName=ParameterTextBox, Path=Text}"
                                                        Style="{StaticResource CustomButtonStyle}"
                                                        Width="100"/>
                                            </StackPanel>

                                            <!-- Pre-Build Events -->
                                            <TextBlock Text="Pre-Build Events:" Margin="0,10,0,5"/>
                                            <ItemsControl ItemsSource="{Binding PreBuildEvents}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox Text="{Binding Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                                     Margin="0,0,5,0"
                                                                     ToolTip="Path"/>
                                                            <TextBox Text="{Binding Arguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                                     Grid.Column="1"
                                                                     ToolTip="Arguments"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <StackPanel>
                                                <DockPanel Margin="0,5">
                                                    <TextBlock Text="Path:" Width="60" VerticalAlignment="Center"/>
                                                    <TextBox x:Name="PathTextBox"
                                                             Height="25"
                                                             VerticalContentAlignment="Center"/>
                                                </DockPanel>

                                                <DockPanel Margin="0,5">
                                                    <TextBlock Text="Arguments:" Width="60" VerticalAlignment="Center"/>
                                                    <TextBox x:Name="ArgumentsTextBox"
                                                             Height="25"
                                                             VerticalContentAlignment="Center"/>
                                                </DockPanel>

                                                <Button Content="Add Pre-Build Event"
                                                        Command="{Binding AddPreBuildEventCommand}">
                                                    <Button.CommandParameter>
                                                        <MultiBinding Converter="{StaticResource ProcessEventConverter}">
                                                            <Binding ElementName="PathTextBox" Path="Text"/>
                                                            <Binding ElementName="ArgumentsTextBox" Path="Text"/>
                                                        </MultiBinding>
                                                    </Button.CommandParameter>
                                                </Button>
                                            </StackPanel>

                                            <!-- Post-Build Events -->
                                            <TextBlock Text="Post-Build Events:" Margin="0,10,0,5"/>
                                            <ItemsControl ItemsSource="{Binding PostBuildEvents}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox Text="{Binding Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                                     Margin="0,0,5,0"
                                                                     ToolTip="Path"/>
                                                            <TextBox Text="{Binding Arguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                                     Grid.Column="1"
                                                                     ToolTip="Arguments"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <StackPanel>
                                                <DockPanel Margin="0,5">
                                                    <TextBlock Text="Path:" Width="60" VerticalAlignment="Center"/>
                                                    <TextBox x:Name="PostPathTextBox"
                                                             Height="25"
                                                             VerticalContentAlignment="Center"/>
                                                </DockPanel>

                                                <DockPanel Margin="0,5">
                                                    <TextBlock Text="Arguments:" Width="60" VerticalAlignment="Center"/>
                                                    <TextBox x:Name="PostArgumentsTextBox"
                                                             Height="25"
                                                             VerticalContentAlignment="Center"/>
                                                </DockPanel>

                                                <Button Content="Add Post-Build Event"
                                                        Command="{Binding AddPostBuildEventCommand}">
                                                    <Button.CommandParameter>
                                                        <MultiBinding Converter="{StaticResource ProcessEventConverter}">
                                                            <Binding ElementName="PostPathTextBox" Path="Text"/>
                                                            <Binding ElementName="PostArgumentsTextBox" Path="Text"/>
                                                        </MultiBinding>
                                                    </Button.CommandParameter>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </Expander>

                                    <!-- Delivery Settings -->
                                    <Expander Header="Delivery Settings" Margin="0,0,0,5">
                                        <StackPanel Margin="20,5">
                                            <CheckBox Content="Enable Delivery" 
                                                    IsChecked="{Binding DeliveryEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Margin="0,0,0,5"/>
                                            
                                            <CheckBox Content="Delivery Bin" 
                                                    IsChecked="{Binding DeliveryBin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Margin="0,0,0,10"/>

                                            <TextBlock Text="Delivery Directories:" Margin="0,0,0,5"/>
                                            <ItemsControl ItemsSource="{Binding DeliveryDirectories}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox Text="{Binding Source}" 
                                                                     Margin="0,0,5,0"
                                                                     ToolTip="Source"/>
                                                            <TextBox Text="{Binding Destination}" 
                                                                     Grid.Column="1"
                                                                     ToolTip="Destination"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <StackPanel>
                                                <DockPanel Margin="0,5">
                                                    <TextBlock Text="Source:" Width="60" VerticalAlignment="Center"/>
                                                    <TextBox x:Name="SourceTextBox"
                                                             Height="25"
                                                             VerticalContentAlignment="Center"/>
                                                </DockPanel>

                                                <DockPanel Margin="0,5">
                                                    <TextBox x:Name="DestinationTextBox"
                                                             Height="25"
                                                             VerticalContentAlignment="Center"/>
                                                </DockPanel>

                                                <Button Content="Add Directory"
                                                        Command="{Binding AddDeliveryDirectoryCommand}">
                                                    <Button.CommandParameter>
                                                        <MultiBinding Converter="{StaticResource DeliveryDirectoryConverter}">
                                                            <Binding ElementName="SourceTextBox" Path="Text"/>
                                                            <Binding ElementName="DestinationTextBox" Path="Text"/>
                                                        </MultiBinding>
                                                    </Button.CommandParameter>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>