                                    ItemsSource="{Binding Urls}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock
                                                    Grid.Column="0"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding}" />

                                                <Button
                                                    Grid.Column="1"
                                                    Width="60"
                                                    Height="22"
                                                    Margin="5,0,0,0"
                                                    Command="{Binding DataContext.RemoveUrlCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                    CommandParameter="{Binding}"
                                                    Content="Remove"
                                                    Style="{StaticResource CustomButtonStyle}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>
                    </Expander>
                </DataTemplate>
            </converters:OperationTemplateSelector.WebBrowserOperationTemplate>

            <converters:OperationTemplateSelector.MsBuildOperationTemplate>
                <DataTemplate>
                    <Expander Margin="0,5,0,0">

                        <!--  Fixed HeaderTemplate  -->
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox
                                    Grid.Column="0"
                                    Height="25"
                                    Margin="0,1,0,0"
                                    VerticalAlignment="Stretch"
                                    BorderBrush="Black"
                                    BorderThickness="0.5"
                                    IsEnabled="{Binding Enabled}"
                                    Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <Button
                                    Grid.Column="1"
                                    Width="70"
                                    Height="25"
                                    Margin="10,0,0,0"
                                    BorderBrush="Black"
                                    BorderThickness="0.5"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.ToggleOperationEnabledCommand}"
                                    CommandParameter="{Binding}"
                                    Content="{Binding Enabled, Converter={StaticResource BoolToEnableDisableTextConverter}}"
                                    Style="{StaticResource CustomButtonStyle}" />

                                <Button
                                    Grid.Column="2"
                                    Width="70"
                                    Height="25"
                                    Margin="10,0,0,0"
                                    BorderBrush="Black"
                                    BorderThickness="0.5"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.RemoveOperationCommand}"
                                    CommandParameter="{Binding}"
                                    Content="Remove"
                                    Style="{StaticResource CustomButtonStyle}" />
                            </Grid>
                        </Expander.Header>

                        <!--  Content section  -->
                        <Grid Margin="10,10,0,0" IsEnabled="{Binding Enabled}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="Name:" />
                            <TextBox
                                Grid.Row="0"
                                Grid.Column="1"
                                Margin="2"
                                BorderBrush="Black"
                                BorderThickness="0.5"
                                Text="{Binding Directory.Name, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="Releative Path:" />
                            <TextBox
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="2"
                                BorderBrush="Black"
                                BorderThickness="0.5"
                                Text="{Binding Directory.Path, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="Retry Count:" />
                            <TextBox
                                Grid.Row="2"
                                Grid.Column="1"
                                Margin="2"
                                BorderBrush="Black"
                                BorderThickness="0.5"
                                Text="{Binding RetryCount, UpdateSourceTrigger=PropertyChanged}" />

                            <!--  Parameters Collection Management  -->
                            <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!--  Add URL input  -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox
                                        x:Name="NewUrlTextBox"
                                        Grid.Column="0"
                                        Margin="2,2,5,2"
                                        BorderBrush="Black"
                                        BorderThickness="0.5" />

                                    <Button
                                        Grid.Column="1"
                                        Width="60"
                                        Height="25"
                                        Command="{Binding AddParameterCommand}"
                                        CommandParameter="{Binding ElementName=NewUrlTextBox, Path=Text}"
                                        Content="Add"
                                        Style="{StaticResource CustomButtonStyle}" />
                                </Grid>

                                <!--  Parametes List  -->
                                <ListView
                                    Grid.Row="4"
                                    Height="120"
                                    Margin="2,5,2,2"
                                    BorderBrush="Black"
                                    BorderThickness="0.5"
                                    ItemsSource="{Binding Parameters}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock
                                                    Grid.Column="0"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding}" />

                                                <Button
                                                    Grid.Column="1"
                                                    Width="60"
                                                    Height="22"
                                                    Margin="5,0,0,0"
                                                    Command="{Binding DataContext.RemoveParameterCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                    CommandParameter="{Binding}"
                                                    Content="Remove"
                                                    Style="{StaticResource CustomButtonStyle}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>
                    </Expander>
                </DataTemplate>
            </converters:OperationTemplateSelector.MsBuildOperationTemplate>

            <converters:OperationTemplateSelector.GitPullOperationTemplate>
                <DataTemplate>
                    <Expander Margin="0,5,0,0">

                        <!--  Fixed HeaderTemplate  -->
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox
                                    Grid.Column="0"
                                    Height="25"
                                    Margin="0,1,0,0"
                                    VerticalAlignment="Stretch"
                                    BorderBrush="Black"
                                    BorderThickness="0.5"
                                    IsEnabled="{Binding Enabled}"
                                    Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <Button
                                    Grid.Column="1"
                                    Width="70"
                                    Height="25"
                                    Margin="10,0,0,0"
                                    BorderBrush="Black"
                                    BorderThickness="0.5"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.ToggleOperationEnabledCommand}"
                                    CommandParameter="{Binding}"
                                    Content="{Binding Enabled, Converter={StaticResource BoolToEnableDisableTextConverter}}"
                                    Style="{StaticResource CustomButtonStyle}" />

                                <Button
                                    Grid.Column="2"
                                    Width="70"
                                    Height="25"
                                    Margin="10,0,0,0"
                                    BorderBrush="Black"
                                    BorderThickness="0.5"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.RemoveOperationCommand}"
                                    CommandParameter="{Binding}"
                                    Content="Remove"
                                    Style="{StaticResource CustomButtonStyle}" />
                            </Grid>
                        </Expander.Header>

                        <!--  Content section  -->
                        <Grid Margin="10,10,0,0" IsEnabled="{Binding Enabled}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="No option yet." />
                        </Grid>
                    </Expander>
                </DataTemplate>
            </converters:OperationTemplateSelector.GitPullOperationTemplate>
        </converters:OperationTemplateSelector>
    </UserControl.Resources>

    <Border Background="{DynamicResource SecondaryBackgroundColor}" CornerRadius="8">
        <StackPanel>
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    Text="Name:" />
                <TextBox
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="0,0,0,0"
                    VerticalAlignment="Center"
                    Text="{Binding Profile.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,10,10,0"
                    VerticalAlignment="Center"
                    Text="Description:" />
                <TextBox
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="0,10,0,0"
                    VerticalAlignment="Center"
                    Text="{Binding Profile.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <!--  Pipeline Steps Section  -->
            <Expander
                Margin="10"
                FontSize="14"
                Header="Pipeline Steps">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Steps List with Add/Remove buttons  -->
                    <Grid
                        Grid.Row="0"
                        Grid.Column="0"
                        Margin="0,0,10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button
                            Grid.Column="1"
                            Width="70"
                            Height="25"
                            Margin="0,0,5,0"
                            Command="{Binding AddStepCommand}"
                            Content="Add Step"
                            FontSize="13"
                            Style="{StaticResource CustomButtonStyle}" />
                    </Grid>

                    <!--  Steps List  -->
                    <Border
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,5,10,0"
                        Background="{DynamicResource TertiaryBackgroundColor}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1">
                        <ListView
                            AllowDrop="True"
                            Background="Transparent"
                            BorderThickness="0"
                            DragOver="ListView_DragOver"
                            Drop="ListView_Drop"
                            ItemContainerStyle="{StaticResource StretchStyle}"
                            ItemsSource="{Binding Profile.Steps}"
                            PreviewMouseLeftButtonDown="ListView_PreviewMouseLeftButtonDown"
                            PreviewMouseMove="ListView_PreviewMouseMove"
                            SelectedItem="{Binding SelectedStep}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <DataTemplate.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontSize" Value="13" />
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}" />
                                            <Setter Property="Margin" Value="10" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                        </Style>
                                    </DataTemplate.Resources>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            Margin="10"
                                            Padding="0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Text="{Binding Name}" />

                                        <Button
                                            Grid.Column="1"
                                            Width="70"
                                            Height="25"
                                            VerticalAlignment="Center"
                                            BorderBrush="Black"
                                            BorderThickness="0.3"
                                            Command="{Binding DataContext.RemoveStepCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="Remove"
                                            FontSize="13"
                                            Style="{StaticResource CustomButtonStyle}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>

                    <!--  Operations for Selected Step  -->
                    <Grid
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="1"
                        Margin="0,0,0,0">
                        <!--  Visibility="{Binding SelectedStep, Converter={StaticResource BoolToVisibilityConverter}}">  -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  Step Details  -->
                        <GroupBox
                            Grid.Row="0"
                            Margin="0,0,0,0"
                            Padding="10"
                            Header="Step Details">
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    Text="Name:" />
                                <TextBox
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Margin="0,0,0,0"
                                    VerticalAlignment="Center"
                                    Text="{Binding SelectedStep.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,10,10,0"
                                    VerticalAlignment="Center"
                                    Text="Description:" />
                                <TextBox
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="0,10,0,0"
                                    VerticalAlignment="Center"
                                    Text="{Binding SelectedStep.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </GroupBox>

                        <!--  Operations  -->
                        <GroupBox
                            Grid.Row="1"
                            Grid.RowSpan="2"
                            Header="Operations">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel
                                    Grid.Row="0"
                                    Margin="10"
                                    HorizontalAlignment="Left"
                                    Orientation="Horizontal">

                                    <ComboBox
                                        Width="150"
                                        Height="25"
                                        Margin="0,0,0,0"
                                        DisplayMemberPath="Name"
                                        ItemsSource="{Binding AvailableOperationTypes}"
                                        SelectedItem="{Binding SelectedOperationType, Mode=TwoWay}"
                                        Style="{DynamicResource ComboBoxStyle}" />

                                    <Button
                                        Width="100"
                                        Height="25"
                                        Margin="10,0,0,0"
                                        Command="{Binding AddOperationCommand}"
                                        Content="Add"
                                        Style="{StaticResource CustomButtonStyle}" />
                                </StackPanel>

                                <!--  Operations List  -->
                                <ListView
                                    Grid.Row="1"
                                    VerticalAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"
                                    Background="{DynamicResource TertiaryBackgroundColor}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1"
                                    ItemTemplateSelector="{StaticResource OperationTemplateSelector}"
                                    ItemsSource="{Binding SelectedStep.Operations}"
                                    ScrollViewer.VerticalScrollBarVisibility="Auto" />
                            </Grid>
                        </GroupBox>
                    </Grid>
                </Grid>
            </Expander>

        </StackPanel>
    </Border>
</UserControl>