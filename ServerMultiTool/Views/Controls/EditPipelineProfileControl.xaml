<UserControl
    x:Class="ServerMultiTool.Views.Controls.EditPipelineProfileControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:ServerMultiTool.ViewModels.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:editPipelineProfile="clr-namespace:ServerMultiTool.ViewModels.Components.EditPipelineProfile"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{d:DesignInstance Type=editPipelineProfile:EditPipelineProfileViewModel,
                                     IsDesignTimeCreatable=True}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  Styles to match PipelineView.xaml  -->
        <Style TargetType="Expander">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="StretchStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource TertiaryBackgroundColor}" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}" />
            <Setter Property="Margin" Value="0,8,0,2" />
        </Style>
        <converters:DeliveryDirectoryConverter x:Key="DeliveryDirectoryConverter" />
        <converters:BoolToEnableDisableTextConverter x:Key="BoolToEnableDisableTextConverter" />
        <converters:OperationTemplateSelector x:Key="OperationTemplateSelector">
            <converters:OperationTemplateSelector.DeliveryBinOperationTemplate>
                <DataTemplate>
                    <Expander Margin="0,5,0,0">

                        <!--  Fixed HeaderTemplate  -->
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox
                                    Grid.Column="0"
                                    Height="25"
                                    Margin="0,1,0,0"
                                    VerticalAlignment="Stretch"
                                    BorderBrush="Black"
                                    BorderThickness="0.5"
                                    IsEnabled="{Binding Enabled}"
                                    Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <Button
                                    Grid.Column="1"
                                    Width="70"
                                    Height="25"
                                    Margin="10,0,0,0"
                                    BorderBrush="Black"
                                    BorderThickness="0.5"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.ToggleOperationEnabledCommand}"
                                    CommandParameter="{Binding}"
                                    Content="{Binding Enabled, Converter={StaticResource BoolToEnableDisableTextConverter}}"
                                    Style="{StaticResource CustomButtonStyle}" />

                                <Button
                                    Grid.Column="2"
                                    Width="70"
                                    Height="25"
                                    Margin="10,0,0,0"
                                    BorderBrush="Black"
                                    BorderThickness="0.5"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.RemoveOperationCommand}"
                                    CommandParameter="{Binding}"
                                    Content="Remove"
                                    Style="{StaticResource CustomButtonStyle}" />
                            </Grid>
                        </Expander.Header>

                        <!--  Content section  -->
                        <Grid Margin="10,10,0,0" IsEnabled="{Binding Enabled}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="Name:" />
                            <TextBox
                                Grid.Row="0"
                                Grid.Column="1"
                                Margin="2"
                                BorderBrush="Black"
                                BorderThickness="0.5"
                                Text="{Binding Directory.Name, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="Releative Path:" />
                            <TextBox
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="2"
                                BorderBrush="Black"
                                BorderThickness="0.5"
                                Text="{Binding Directory.Path, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Expander>
                </DataTemplate>
            </converters:OperationTemplateSelector.DeliveryBinOperationTemplate>

            <converters:OperationTemplateSelector.DeliverySpecifiedFilesOperationTemplate>
                <DataTemplate>
                    <Expander Margin="0,5,0,0">

                        <!--  Fixed HeaderTemplate  -->
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox
                                    Grid.Column="0"
                                    Height="25"
                                    Margin="0,1,0,0"
                                    VerticalAlignment="Stretch"
                                    BorderBrush="Black"
                                    BorderThickness="0.5"
                                    IsEnabled="{Binding Enabled}"
                                    Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <Button
                                    Grid.Column="1"
                                    Width="70"
                                    Height="25"
                                    Margin="10,0,0,0"
                                    BorderBrush="Black"
                                    BorderThickness="0.5"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.ToggleOperationEnabledCommand}"
                                    CommandParameter="{Binding}"
                                    Content="{Binding Enabled, Converter={StaticResource BoolToEnableDisableTextConverter}}"
                                    Style="{StaticResource CustomButtonStyle}" />

                                <Button
                                    Grid.Column="2"
                                    Width="70"
                                    Height="25"
                                    Margin="10,0,0,0"
                                    BorderBrush="Black"
                                    BorderThickness="0.5"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.RemoveOperationCommand}"
                                    CommandParameter="{Binding}"
                                    Content="Remove"
                                    Style="{StaticResource CustomButtonStyle}" />
                            </Grid>
                        </Expander.Header>

                        <!--  Content section  -->
                        <Grid Margin="10,10,0,0" IsEnabled="{Binding Enabled}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <GroupBox
                                Grid.Row="0"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Header="Delivery Dirictories">
                                <!--  Delivery Directories Collection Management  -->
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!--  Add Directory input  -->
                                    <Grid Grid.Row="0" Margin="2,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Margin="0,5,0,0"
                                            VerticalAlignment="Center"
                                            Text="Source:" />
                                        <TextBox
                                            x:Name="SourceTextBox"
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            Height="25"
                                            MinWidth="200"
                                            Margin="10,5,0,0"
                                            VerticalContentAlignment="Center" />

                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Margin="0,5,0,0"
                                            VerticalAlignment="Center"
                                            Text="Destination:" />
                                        <TextBox
                                            x:Name="DestinationTextBox"
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Height="25"
                                            MinWidth="200"
                                            Margin="10,5,0,0"
                                            VerticalContentAlignment="Center" />

                                        <Button
                                            Grid.Row="0"
                                            Grid.RowSpan="2"
                                            Grid.Column="2"
                                            Height="25"
                                            MinWidth="70"
                                            Margin="10,5,0,0"
                                            VerticalAlignment="Center"
                                            Command="{Binding AddDeliveryDirectoryCommand}"
                                            Content="Add"
                                            Style="{StaticResource CustomButtonStyle}">
                                            <Button.CommandParameter>
                                                <MultiBinding Converter="{StaticResource DeliveryDirectoryConverter}">
                                                    <Binding ElementName="SourceTextBox" Path="Text" />
                                                    <Binding ElementName="DestinationTextBox" Path="Text" />
                                                </MultiBinding>
                                            </Button.CommandParameter>
                                        </Button>
                                    </Grid>

                                    <!--  Directories List  -->
                                    <ListView
                                        Grid.Row="1"
                                        Height="120"
                                        Margin="2,5,2,2"
                                        BorderBrush="Black"
                                        BorderThickness="0.5"
                                        ItemsSource="{Binding Directories}">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock
                                                        Grid.Column="0"
                                                        VerticalAlignment="Center"
                                                        Text="{Binding Source}" />

                                                    <TextBlock
                                                        Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Text="{Binding Destination}" />

                                                    <Button
                                                        Grid.Column="2"
                                                        Width="60"
                                                        Height="22"
                                                        Margin="5,0,0,0"
                                                        Command="{Binding DataContext.RemoveDirectoryCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                        CommandParameter="{Binding}"
                                                        Content="Remove"
                                                        Style="{StaticResource CustomButtonStyle}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Grid>
                            </GroupBox>
                        </Grid>
                    </Expander>
                </DataTemplate>
            </converters:OperationTemplateSelector.DeliverySpecifiedFilesOperationTemplate>

            <converters:OperationTemplateSelector.HttpPingOperationTemplate>
                <DataTemplate>
                    <Expander Margin="0,5,0,0">

                        <!--  Fixed HeaderTemplate  -->
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox
                                    Grid.Column="0"
                                    Height="25"
                                    Margin="0,1,0,0"
                                    VerticalAlignment="Stretch"
                                    BorderBrush="Black"
                                    BorderThickness="0.5"
                                    IsEnabled="{Binding Enabled}"
                                    Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <Button
                                    Grid.Column="1"
                                    Width="70"
                                    Height="25"
                                    Margin="10,0,0,0"
                                    BorderBrush="Black"
                                    BorderThickness="0.5"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.ToggleOperationEnabledCommand}"
                                    CommandParameter="{Binding}"
                                    Content="{Binding Enabled, Converter={StaticResource BoolToEnableDisableTextConverter}}"
                                    Style="{StaticResource CustomButtonStyle}" />

                                <Button
                                    Grid.Column="2"
                                    Width="70"
                                    Height="25"
                                    Margin="10,0,0,0"
                                    BorderBrush="Black"
                                    BorderThickness="0.5"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.RemoveOperationCommand}"
                                    CommandParameter="{Binding}"
                                    Content="Remove"
                                    Style="{StaticResource CustomButtonStyle}" />
                            </Grid>
                        </Expander.Header>

                        <!--  Content section  -->
                        <Grid Margin="10,10,0,0" IsEnabled="{Binding Enabled}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="Timeout:" />
                            <TextBox
                                Grid.Row="0"
                                Grid.Column="1"
                                Margin="2"
                                BorderBrush="Black"
                                BorderThickness="0.5"
                                Text="{Binding TimeoutInMinutes, UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="In minutes (double)" />

                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="URLs:" />

                            <!--  URL Collection Management  -->
                            <Grid Grid.Row="2" Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!--  Add URL input  -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox
                                        x:Name="NewUrlTextBox"
                                        Grid.Column="0"
                                        Margin="2,2,5,2"
                                        BorderBrush="Black"
                                        BorderThickness="0.5" />

                                    <Button
                                        Grid.Column="1"
                                        Width="60"
                                        Height="25"
                                        Command="{Binding AddUrlCommand}"
                                        CommandParameter="{Binding ElementName=NewUrlTextBox, Path=Text}"
                                        Content="Add"
                                        Style="{StaticResource CustomButtonStyle}" />
                                </Grid>

                                <!--  URL List  -->
                                <ListView
                                    Grid.Row="1"
                                    Height="120"
                                    Margin="2,5,2,2"
                                    BorderBrush="Black"
                                    BorderThickness="0.5"
                                    ItemsSource="{Binding Urls}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock
                                                    Grid.Column="0"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding}" />

                                                <Button
                                                    Grid.Column="1"
                                                    Width="60"
                                                    Height="22"
                                                    Margin="5,0,0,0"
                                                    Command="{Binding DataContext.RemoveUrlCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                    CommandParameter="{Binding}"
                                                    Content="Remove"
                                                    Style="{StaticResource CustomButtonStyle}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>
                    </Expander>
                </DataTemplate>
            </converters:OperationTemplateSelector.HttpPingOperationTemplate>

            <converters:OperationTemplateSelector.ProcessExecutionOperationTemplate>
                <DataTemplate>
                    <Expander Margin="0,5,0,0">

                        <!--  Fixed HeaderTemplate  -->
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox
                                    Grid.Column="0"
                                    Height="25"
                                    Margin="0,1,0,0"
                                    VerticalAlignment="Stretch"
                                    BorderBrush="Black"
                                    BorderThickness="0.5"
                                    IsEnabled="{Binding Enabled}"
                                    Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <Button
                                    Grid.Column="1"
                                    Width="70"
                                    Height="25"
                                    Margin="10,0,0,0"
                                    BorderBrush="Black"
                                    BorderThickness="0.5"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.ToggleOperationEnabledCommand}"
                                    CommandParameter="{Binding}"
                                    Content="{Binding Enabled, Converter={StaticResource BoolToEnableDisableTextConverter}}"
                                    Style="{StaticResource CustomButtonStyle}" />

                                <Button
                                    Grid.Column="2"
                                    Width="70"
                                    Height="25"
                                    Margin="10,0,0,0"
                                    BorderBrush="Black"
                                    BorderThickness="0.5"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.RemoveOperationCommand}"
                                    CommandParameter="{Binding}"
                                    Content="Remove"
                                    Style="{StaticResource CustomButtonStyle}" />
                            </Grid>
                        </Expander.Header>

                        <!--  Content section  -->
                        <Grid Margin="10,10,0,0" IsEnabled="{Binding Enabled}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="File Name:" />
                            <TextBox
                                Grid.Row="0"
                                Grid.Column="1"
                                Margin="2"
                                BorderBrush="Black"
                                BorderThickness="0.5"
                                Text="{Binding FileName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="Arguments:" />
                            <TextBox
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="2"
                                BorderBrush="Black"
                                BorderThickness="0.5"
                                Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="Retry Count:" />
                            <TextBox
                                Grid.Row="2"
                                Grid.Column="1"
                                Margin="2"
                                BorderBrush="Black"
                                BorderThickness="0.5"
                                Text="{Binding RetryCount, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Expander>
                </DataTemplate>
            </converters:OperationTemplateSelector.ProcessExecutionOperationTemplate>

            <converters:OperationTemplateSelector.SqlExecutionOperationTemplate>
                <DataTemplate>
                    <Expander Margin="0,5,0,0">

                        <!--  Fixed HeaderTemplate  -->
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox
                                    Grid.Column="0"
                                    Height="25"
                                    Margin="0,1,0,0"
