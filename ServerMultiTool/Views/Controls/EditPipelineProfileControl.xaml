<UserControl x:Class="ServerMultiTool.Views.Controls.EditPipelineProfileControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:editPipelineProfile="clr-namespace:ServerMultiTool.ViewModels.Controls.EditPipelineProfile"
             xmlns:converters1="clr-namespace:ServerMultiTool.ViewModels.Controls.EditPipelineProfile.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=editPipelineProfile:EditPipelineProfileViewModel, IsDesignTimeCreatable=True}">
    
    <UserControl.Resources>
        <converters1:ProcessEventConverter x:Key="ProcessEventConverter"/>
        <converters1:DeliveryDirectoryConverter x:Key="DeliveryDirectoryConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <!-- Поле для имени -->
            <DockPanel Margin="0,0,0,10">
                <TextBlock Text="Profile Name:" 
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"
                          Foreground="{DynamicResource PrimaryTextColor}"/>
                <TextBox Text="{Binding Profile.Name, UpdateSourceTrigger=PropertyChanged}"
                         Height="25"/>
            </DockPanel>

            <!-- Глобальные настройки -->
            <StackPanel Margin="0,0,0,10">
                <TextBlock Text="Global Settings:"
                          Margin="0,0,0,5"
                          Foreground="{DynamicResource PrimaryTextColor}"/>
                
                <CheckBox Content="Git" 
                         IsChecked="{Binding Profile.GitSettings.Enable}"
                         Margin="5"
                         Foreground="{DynamicResource PrimaryTextColor}"/>
                
                <CheckBox Content="IIS" 
                         IsChecked="{Binding Profile.InternetInformationSettings.Enable}"
                         Margin="5"
                         Foreground="{DynamicResource PrimaryTextColor}"/>
                
                <CheckBox Content="SQL" 
                         IsChecked="{Binding Profile.SqlExecutionSettings.Enable}"
                         Margin="5"
                         Foreground="{DynamicResource PrimaryTextColor}"/>
                
                <CheckBox Content="Web Browser" 
                         IsChecked="{Binding Profile.WebBrowserSettings.Enable}"
                         Margin="5"
                         Foreground="{DynamicResource PrimaryTextColor}"/>
                
                <CheckBox Content="HTTP Monitoring" 
                         IsChecked="{Binding Profile.HttpMonitoringSettings.Enable}"
                         Margin="5"
                         Foreground="{DynamicResource PrimaryTextColor}"/>
                
                <CheckBox Content="Monitor Log Files" 
                         IsChecked="{Binding Profile.MonitorLogFilesSettings.Enable}"
                         Margin="5"
                         Foreground="{DynamicResource PrimaryTextColor}"/>
            </StackPanel>


            <!-- Настройки проектов -->
            <StackPanel>
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Project Settings:"
                             Margin="0,0,10,0"
                             Foreground="{DynamicResource PrimaryTextColor}"/>
                    <Button Content="Add Project"
                            Command="{Binding AddProjectCommand}"
                            Style="{StaticResource CustomButtonStyle}"
                            HorizontalAlignment="Right"
                            Width="100"
                            Height="25"/>
                </DockPanel>

                <ItemsControl ItemsSource="{Binding ProjectSettings}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SecondaryBackgroundColor}"
                                    Margin="0,0,0,10"
                                    Padding="10"
                                    CornerRadius="5">
                                <StackPanel>
                                    <!-- Project Info -->
                                    <DockPanel Margin="0,0,0,10">
                                        <Button Content="Remove"
                                                Command="{Binding DataContext.RemoveProjectCommand, 
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource CustomButtonStyle}"
                                                DockPanel.Dock="Right"
                                                Width="70"
                                                Height="25"/>
                                        
                                        <StackPanel>
                                            <DockPanel Margin="0,0,10,5">
                                                <TextBlock Text="Name:" Width="50"/>
                                                <TextBox Text="{Binding ProjectName}" Height="25"/>
                                            </DockPanel>
                                            <DockPanel Margin="0,0,10,0">
                                                <TextBlock Text="Path:" Width="50"/>
                                                <TextBox Text="{Binding ProjectPath}" Height="25"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- MSBuild Settings -->
                                    <Expander Header="Build Settings" Margin="0,0,0,5">
                                        <StackPanel Margin="20,5">
                                            <CheckBox Content="Enable MSBuild" 
                                                      IsChecked="{Binding MsBuildEnabled}"
                                                      Margin="0,0,0,5"/>

                                            <TextBlock Text="Build Parameters:" Margin="0,5"/>
                                            <ItemsControl ItemsSource="{Binding BuildParameters}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding Path=., Mode=TwoWay}" Margin="0,2"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                                <TextBox x:Name="ParameterTextBox"
                                                         Width="200"
                                                         Height="25"
                                                         Margin="0,0,10,0"
                                                         VerticalContentAlignment="Center"/>
    
                                                <Button Content="Add"
                                                        Command="{Binding AddBuildParameterCommand}"
                                                        CommandParameter="{Binding ElementName=ParameterTextBox, Path=Text}"
                                                        Style="{StaticResource CustomButtonStyle}"
                                                        Width="100"/>
                                            </StackPanel>


                                            <!-- Pre-Build Events -->
                                            <TextBlock Text="Pre-Build Events:" Margin="0,10,0,5"/>
                                            <ItemsControl ItemsSource="{Binding PreBuildEvents}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox Text="{Binding Path, Mode=TwoWay}" 
                                                                     Margin="0,0,5,0"
                                                                     ToolTip="Path"/>
                                                            <TextBox Text="{Binding Arguments, Mode=TwoWay}" 
                                                                     Grid.Column="1"
                                                                     ToolTip="Arguments"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <StackPanel>
                                                <DockPanel Margin="0,5">
                                                    <TextBlock Text="Path:" Width="60" VerticalAlignment="Center"/>
                                                    <TextBox x:Name="PathTextBox"
                                                             Height="25"
                                                             VerticalContentAlignment="Center"/>
                                                </DockPanel>

                                                <DockPanel Margin="0,5">
                                                    <TextBlock Text="Arguments:" Width="60" VerticalAlignment="Center"/>
                                                    <TextBox x:Name="ArgumentsTextBox"
                                                             Height="25"
                                                             VerticalContentAlignment="Center"/>
                                                </DockPanel>

                                                <Button Content="Add Pre-Build Event"
                                                        Command="{Binding AddPreBuildEventCommand}">
                                                    <Button.CommandParameter>
                                                        <MultiBinding Converter="{StaticResource ProcessEventConverter}">
                                                            <Binding ElementName="PathTextBox" Path="Text"/>
                                                            <Binding ElementName="ArgumentsTextBox" Path="Text"/>
                                                        </MultiBinding>
                                                    </Button.CommandParameter>
                                                </Button>
                                            </StackPanel>

                                            <!-- Post-Build Events -->
                                            <TextBlock Text="Post-Build Events:" Margin="0,10,0,5"/>
                                            <ItemsControl ItemsSource="{Binding PostBuildEvents}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox Text="{Binding Path, Mode=TwoWay}" 
                                                                     Margin="0,0,5,0"
                                                                     ToolTip="Path"/>
                                                            <TextBox Text="{Binding Arguments, Mode=TwoWay}" 
                                                                     Grid.Column="1"
                                                                     ToolTip="Arguments"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <StackPanel>
                                                <DockPanel Margin="0,5">
                                                    <TextBlock Text="Path:" Width="60" VerticalAlignment="Center"/>
                                                    <TextBox x:Name="PostPathTextBox"
                                                             Height="25"
                                                             VerticalContentAlignment="Center"/>
                                                </DockPanel>

                                                <DockPanel Margin="0,5">
                                                    <TextBlock Text="Arguments:" Width="60" VerticalAlignment="Center"/>
                                                    <TextBox x:Name="PostArgumentsTextBox"
                                                             Height="25"
                                                             VerticalContentAlignment="Center"/>
                                                </DockPanel>

                                                <Button Content="Add Post-Build Event"
                                                        Command="{Binding AddPostBuildEventCommand}">
                                                    <Button.CommandParameter>
                                                        <MultiBinding Converter="{StaticResource ProcessEventConverter}">
                                                            <Binding ElementName="PostPathTextBox" Path="Text"/>
                                                            <Binding ElementName="PostArgumentsTextBox" Path="Text"/>
                                                        </MultiBinding>
                                                    </Button.CommandParameter>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </Expander>

                                    <!-- Delivery Settings -->
                                    <Expander Header="Delivery Settings" Margin="0,0,0,5">
                                        <StackPanel Margin="20,5">
                                            <CheckBox Content="Enable Delivery" 
                                                    IsChecked="{Binding DeliveryEnabled}"
                                                    Margin="0,0,0,5"/>
                                            
                                            <CheckBox Content="Delivery Bin" 
                                                    IsChecked="{Binding DeliveryBin}"
                                                    Margin="0,0,0,10"/>

                                            <TextBlock Text="Delivery Directories:" Margin="0,0,0,5"/>
                                            <ItemsControl ItemsSource="{Binding DeliveryDirectories}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox Text="{Binding Source}" 
                                                                     Margin="0,0,5,0"
                                                                     ToolTip="Source"/>
                                                            <TextBox Text="{Binding Destination}" 
                                                                     Grid.Column="1"
                                                                     ToolTip="Destination"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <StackPanel>
                                                <DockPanel Margin="0,5">
                                                    <TextBlock Text="Source:" Width="60" VerticalAlignment="Center"/>
                                                    <TextBox x:Name="SourceTextBox"
                                                             Height="25"
                                                             VerticalContentAlignment="Center"/>
                                                </DockPanel>

                                                <DockPanel Margin="0,5">
                                                    <TextBlock Text="Destination:" Width="60" VerticalAlignment="Center"/>
                                                    <TextBox x:Name="DestinationTextBox"
                                                             Height="25"
                                                             VerticalContentAlignment="Center"/>
                                                </DockPanel>

                                                <Button Content="Add Directory"
                                                        Command="{Binding AddDeliveryDirectoryCommand}">
                                                    <Button.CommandParameter>
                                                        <MultiBinding Converter="{StaticResource DeliveryDirectoryConverter}">
                                                            <Binding ElementName="SourceTextBox" Path="Text"/>
                                                            <Binding ElementName="DestinationTextBox" Path="Text"/>
                                                        </MultiBinding>
                                                    </Button.CommandParameter>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>