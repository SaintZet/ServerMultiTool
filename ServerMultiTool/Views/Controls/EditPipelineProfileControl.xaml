                                    Style="{StaticResource CustomButtonStyle}" />

                                <Button
                                    Grid.Column="2"
                                    Width="70"
                                    Height="25"
                                    Margin="10,0,0,0"
                                    BorderBrush="Black"
                                    BorderThickness="0.5"
                                    Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.RemoveOperationCommand}"
                                    CommandParameter="{Binding}"
                                    Content="Remove"
                                    Style="{StaticResource CustomButtonStyle}" />
                            </Grid>
                        </Expander.Header>

                        <!--  Content section  -->
                        <Grid Margin="10,10,0,0" IsEnabled="{Binding Enabled}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="Path to SQL script:" />
                            <TextBox
                                Grid.Row="0"
                                Grid.Column="1"
                                Margin="2"
                                BorderBrush="Black"
                                BorderThickness="0.5"
                                Text="{Binding PathToSqlScript, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Text="Connection String:" />
                            <TextBox
                                Grid.Row="2"
                                Grid.Column="1"
                                Margin="2"
                                BorderBrush="Black"
                                BorderThickness="0.5"
                                Text="{Binding ConnectionString, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Expander>
                </DataTemplate>
            </converters:OperationTemplateSelector.SqlExecutionOperationTemplate>

            <converters:OperationTemplateSelector.WebBrowserOperationTemplate>
