<UserControl x:Class="ServerMultiTool.Views.Controls.EditPipelineProfileControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:editPipelineProfile="clr-namespace:ServerMultiTool.ViewModels.Controls.EditPipelineProfile"
             xmlns:converters1="clr-namespace:ServerMultiTool.ViewModels.Controls.EditPipelineProfile.Converters"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=editPipelineProfile:EditPipelineProfileViewModel, IsDesignTimeCreatable=True}">

    <UserControl.Resources>
        <converters1:ProcessEventConverter x:Key="ProcessEventConverter"/>
        <converters1:DeliveryDirectoryConverter x:Key="DeliveryDirectoryConverter"/>

        <!-- Styles to match PipelineView.xaml -->
        <Style TargetType="Expander">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}" />
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource TertiaryBackgroundColor}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}" />
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}" />
            <Setter Property="Margin" Value="0,8,0,2" />
        </Style>
    </UserControl.Resources>

    <Border CornerRadius="8">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0" HorizontalAlignment="Left">
                <!-- Git Settings -->
                <Expander Header="Git Settings" IsExpanded="True">
                    <StackPanel Margin="18,6,5,2">
                        <CheckBox Content="Enable Git"
                                  IsChecked="{Binding Profile.GitSettings.Enable, 
                                  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <CheckBox Content="Should Pull"
                                  IsChecked="{Binding Profile.GitSettings.ShouldPull, 
                                  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Expander>

                <!-- IIS Settings -->
                <Expander Header="IIS Settings">
                    <StackPanel Margin="18,6,5,2">
                        <CheckBox Content="Enable IIS Restart"
                                  IsChecked="{Binding Profile.InternetInformationSettings.Enable, 
                                  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  />
                    </StackPanel>
                </Expander>

                <!-- SQL Settings -->
                <Expander Header="SQL Settings">
                    <StackPanel Margin="18,6,5,2">
                        <CheckBox Content="Enable SQL Execution" IsChecked="{Binding Profile.SqlExecutionSettings.Enable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Connection String:"/>
                        <TextBox Text="{Binding Profile.SqlExecutionSettings.ConnectionString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Path to SQL script:"/>
                        <TextBox Text="{Binding Profile.SqlExecutionSettings.PathToSqlScript, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Expander>

                <!-- Web Browser Settings -->
                <Expander Header="Web Browser Settings">
                    <StackPanel Margin="18,6,5,2">
                        <CheckBox Content="Enable open window in Web Browser"
                                  IsChecked="{Binding Profile.WebBrowserSettings.Enable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="URL:" VerticalAlignment="Center" Margin="0,0,5,0"/>

                            <TextBox Grid.Column="1"
                                     Text="{Binding Profile.WebBrowserSettings.Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,0"
                                     MinWidth="200"/>
                        </Grid>
                    </StackPanel>
                </Expander>
                
                <!-- HTTP Monitoring Settings-->
                <Expander Header="HTTP Monitoring Settings">
                    <StackPanel Margin="18,6,5,2">
                        <CheckBox Content="Enable HTTP Monitoring"
                                  IsChecked="{Binding Profile.HttpMonitoringSettings.Enable, 
                                  Mode=TwoWay, 
                                  UpdateSourceTrigger=PropertyChanged}"/>
                        <CheckBox Content="Ping Master"
                                  IsChecked="{Binding Profile.HttpMonitoringSettings.PingMaster, 
                                  Mode=TwoWay, 
                                  UpdateSourceTrigger=PropertyChanged}"/>
                        <CheckBox Content="Ping Segment"
                                  IsChecked="{Binding Profile.HttpMonitoringSettings.PingSegment, 
                                  Mode=TwoWay, 
                                  UpdateSourceTrigger=PropertyChanged}"/>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Timeout (in minutes):" 
                                       VerticalAlignment="Center" 
                                       Margin="0,0,5,0"/>

                            <TextBox Grid.Column="1"
                                     Text="{Binding Profile.HttpMonitoringSettings.TimeoutMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,0"
                                     HorizontalAlignment="Left"
                                     Height="20"
                                     Width="30"/>
                        </Grid>
                    </StackPanel>
                </Expander>
                
                <!-- Settings Per Project -->
                <StackPanel Margin="0,10,0,0">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Settings Per Project:"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryTextColor}" />

                        <Button Grid.Column="1"
                                Content="Add"
                                Command="{Binding AddProjectCommand}"
                                Style="{StaticResource CustomButtonStyle}"
                                Width="70"
                                Height="25"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                                Margin="100,10,0,0"
                                Padding="0"
                                BorderThickness="0.5"
                                BorderBrush="Black" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding ProjectSettings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SecondaryBackgroundColor}"
                                        Margin="0,0,0,10"
                                        Padding="10"
                                        CornerRadius="5">
                                    <StackPanel>
                                        <!-- Project Info -->
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0" Margin="0,0,0,0" IsSharedSizeScope="True">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Lbl"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="Name:"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,5,0"/>
                                                <TextBox  Grid.Row="0" Grid.Column="1"
                                                          Text="{Binding ProjectName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Margin="0,0,0,0"
                                                          MinWidth="200"/>

                                                <TextBlock Grid.Row="1" Grid.Column="0"
                                                           Text="Path:"
                                                           VerticalAlignment="Center"
                                                           Margin="0,5,5,0"/>
                                                <TextBox  Grid.Row="1" Grid.Column="1"
                                                          Text="{Binding ProjectPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Margin="0,5,0,0"
                                                          MinWidth="200"/>
                                            </Grid>

                                            <Button Grid.Column="1"
                                                    Content="Remove"
                                                    Command="{Binding DataContext.RemoveProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource CustomButtonStyle}"
                                                    Width="70"
                                                    Height="25"
                                                    Margin="20, 0, 0, 0"
                                                    VerticalAlignment="Center"/>
                                        </Grid>

                                        <!-- MSBuild Settings -->
                                        <Expander Header="Build Settings" >
                                            <StackPanel Margin="20,10,0,10">
                                                <CheckBox Content="Enable MSBuild" IsChecked="{Binding MsBuildEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                <!-- Build Parameters -->
                                                <GroupBox Header="Build Parameters" Margin="0,10,0,0">
                                                    <StackPanel>
                                                        <!-- Список Build Parameters -->
                                                        <ItemsControl ItemsSource="{Binding BuildParameters}" Margin="0,5,0,0">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid Margin="0,2">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <!-- Текстовое поле параметра -->
                                                                        <TextBox Grid.Column="0"
                                                                                 Text="{Binding ., Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                 Height="25"
                                                                                 Margin="0,0,10,0"
                                                                                 VerticalContentAlignment="Center" />

                                                                        <!-- Кнопка Remove -->
                                                                        <Button Grid.Column="1"
                                                                                Content="Remove"
                                                                                Style="{StaticResource CustomButtonStyle}"
                                                                                MinWidth="70"
                                                                                Height="25"
                                                                                Command="{Binding DataContext.RemoveBuildParameterCommand,
                                                                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                CommandParameter="{Binding}" />
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <Grid Margin="0,5">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <TextBox x:Name="ParameterTextBox"
                                                                     Grid.Column="0"
                                                                     Height="25"
                                                                     Margin="0,0,10,0"
                                                                     VerticalContentAlignment="Center"/>

                                                            <Button Grid.Column="1"
                                                                    Content="Add"
                                                                    Command="{Binding AddBuildParameterCommand}"
                                                                    CommandParameter="{Binding ElementName=ParameterTextBox, Path=Text}"
                                                                    Style="{StaticResource CustomButtonStyle}"
                                                                    MinWidth="70"
                                                                    Height="25"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </GroupBox>
                                                <!-- Build Parameters -->

                                                <!-- Pre-Build Events -->
                                                <GroupBox Header="Pre-Build Events" Margin="0,10,0,0">
                                                    <StackPanel>
                                                        <ItemsControl ItemsSource="{Binding PreBuildEvents}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid Margin="0,2">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBox Text="{Binding Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                                             Margin="0,0,5,0"
                                                                             ToolTip="Path"/>
                                                                        <TextBox Text="{Binding Arguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                                             Grid.Column="1"
                                                                             ToolTip="Arguments"/>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <Grid Margin="0,5,0,0" IsSharedSizeScope="True">

                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" SharedSizeGroup="Labels"/>
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Row 0: Path -->
                                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                                   Text="Path:"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,5,0,0"/>
                                                            <TextBox x:Name="PathTextBox"
                                                                 Grid.Row="0" Grid.Column="1"
                                                                 Height="25"
                                                                 VerticalContentAlignment="Center"
                                                                 MinWidth="200"
                                                                 Margin="10,5,0,0"/>

                                                            <!-- Row 1: Arguments -->
                                                            <TextBlock Grid.Row="1" Grid.Column="0"
                                                                   Text="Arguments:"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,5,0,0"/>
                                                            <TextBox x:Name="ArgumentsTextBox"
                                                                 Grid.Row="1" Grid.Column="1"
                                                                 Height="25"
                                                                 Margin="10,5,0,0"
                                                                 VerticalContentAlignment="Center"
                                                                 MinWidth="200"/>

                                                            <!-- Row 2: Button -->
                                                            <Button Grid.Row="2" Grid.Column="1"
                                                                Content="Add"
                                                                Command="{Binding AddPreBuildEventCommand}"
                                                                Style="{StaticResource CustomButtonStyle}"
                                                                HorizontalAlignment="Right"
                                                                Margin="0,10,0,0"
                                                                MinWidth="70"
                                                                Height="25">
                                                                <Button.CommandParameter>
                                                                    <MultiBinding Converter="{StaticResource ProcessEventConverter}">
                                                                        <Binding ElementName="PathTextBox" Path="Text"/>
                                                                        <Binding ElementName="ArgumentsTextBox" Path="Text"/>
                                                                    </MultiBinding>
                                                                </Button.CommandParameter>
                                                            </Button>
                                                        </Grid>
                                                    </StackPanel>
                                                </GroupBox>
                                                <!-- Pre-Build Events -->

                                                <!-- Post-Build Events -->
                                                <GroupBox Header="Post-Build Events" Margin="0,10,0,0">
                                                    <StackPanel>
                                                        <!-- Post-Build Events список -->
                                                        <ItemsControl Margin="0,10,0,10" ItemsSource="{Binding PostBuildEvents}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid>
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="Auto"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                        </Grid.RowDefinitions>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="Labels"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <!-- ───────── Path ───────── -->
                                                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                                                   Text="Path:"
                                                                                   VerticalAlignment="Center"
                                                                                   Margin="0,5,0,0"/>
                                                                        <TextBox  Grid.Row="0" Grid.Column="1"
                                                                                  Text="{Binding Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                  VerticalContentAlignment="Center"
                                                                                  Margin="10,5,0,0"/>

                                                                        <!-- ──────── Arguments ──────── -->
                                                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                                                   Text="Arguments:"
                                                                                   VerticalAlignment="Center"
                                                                                   Margin="0,5,0,0"/>
                                                                        <TextBox  Grid.Row="1" Grid.Column="1"
                                                                                  Text="{Binding Arguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                  VerticalContentAlignment="Center"
                                                                                  Margin="10,5,0,0"/>

                                                                        <!-- ──────── Remove btn ──────── -->
                                                                        <Button   Grid.Row="2" Grid.Column="1"
                                                                                  Content="Remove"
                                                                                  Style="{StaticResource CustomButtonStyle}"
                                                                                  HorizontalAlignment="Right"
                                                                                  Margin="0,10,0,0"
                                                                                  MinWidth="70" Height="25"
                                                                                  Command="{Binding DataContext.RemovePostBuildEventCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                  CommandParameter="{Binding}" />
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                        <Grid Margin="0,10,0,10" IsSharedSizeScope="True">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" SharedSizeGroup="Labels"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Row 0: Path -->
                                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                                       Text="Path:"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,5,0,0"/>
                                                            <TextBox x:Name="PostPathTextBox"
                                                                     Grid.Row="0" Grid.Column="1"
                                                                     Height="25"
                                                                     VerticalContentAlignment="Center"
                                                                     MinWidth="200"
                                                                     Margin="10,5,0,0"/>

                                                            <!-- Row 1: Arguments -->
                                                            <TextBlock Grid.Row="1" Grid.Column="0"
                                                                       Text="Arguments:"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,5,0,0"/>
                                                            <TextBox x:Name="PostArgumentsTextBox"
                                                                     Grid.Row="1" Grid.Column="1"
                                                                     Height="25"
                                                                     Margin="10,5,0,0"
                                                                     VerticalContentAlignment="Center"
                                                                     MinWidth="200"/>

                                                            <!-- Row 2: Button -->
                                                            <Button Grid.Row="2" Grid.Column="1"
                                                                    Content="Add"
                                                                    Command="{Binding AddPostBuildEventCommand}"
                                                                    Style="{StaticResource CustomButtonStyle}"
                                                                    HorizontalAlignment="Right"
                                                                    Margin="0,10,0,0"
                                                                    MinWidth="70"
                                                                    Height="25">
                                                                <Button.CommandParameter>
                                                                    <MultiBinding Converter="{StaticResource ProcessEventConverter}">
                                                                        <Binding ElementName="PostPathTextBox" Path="Text"/>
                                                                        <Binding ElementName="PostArgumentsTextBox" Path="Text"/>
                                                                    </MultiBinding>
                                                                </Button.CommandParameter>
                                                            </Button>
                                                        </Grid>
                                                    </StackPanel>
                                                </GroupBox>
                                                <!-- Post-Build Events -->
                                            </StackPanel>
                                        </Expander>

                                        <!-- Delivery Settings -->
                                        <Expander Header="Delivery Settings" >
                                            <StackPanel Margin="20,10,0,10">
                                                <CheckBox Content="Delivery Bin" IsChecked="{Binding EnableDeliveryBin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                
                                                <CheckBox Content="Enable Custom Delivery" IsChecked="{Binding EnableCustomDelivery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                <GroupBox Header="Custom Delivery Directories" Margin="0,10,0,0">
                                                    
                                                    <Grid IsSharedSizeScope="True">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <!-- Список добавленных директорий -->
                                                        <ItemsControl Grid.Row="0" ItemsSource="{Binding DeliveryDirectories}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid Margin="0,5,0,0">
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="Auto"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                        </Grid.RowDefinitions>

                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="Labels"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <!-- Source -->
                                                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                                                   Text="Source:"
                                                                                   VerticalAlignment="Center"
                                                                                   Margin="0,5,0,0"/>
                                                                        <TextBox  Grid.Row="0" Grid.Column="1" 
                                                                                  Text="{Binding Source}"
                                                                                  Margin="10,5,0,0"
                                                                                  VerticalContentAlignment="Center"/>

                                                                        <!-- Destination -->
                                                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                                                   Text="Destination:"
                                                                                   VerticalAlignment="Center"
                                                                                   Margin="0,5,0,0"/>
                                                                        <TextBox  Grid.Row="1" Grid.Column="1"
                                                                                  Text="{Binding Destination}"
                                                                                  Margin="10,5,0,0"
                                                                                  VerticalContentAlignment="Center"/>

                                                                        <!-- Кнопка удаления (третья строка) -->
                                                                        <Button Grid.Row="2" Grid.Column="1"
                                                                                Command="{Binding DataContext.RemoveDeliveryDirectoryCommand,RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                CommandParameter="{Binding}"
                                                                                Content="Remove"
                                                                                Style="{StaticResource CustomButtonStyle}"
                                                                                HorizontalAlignment="Right"
                                                                                Margin="0,10,0,0"
                                                                                MinWidth="70"
                                                                                Height="25" />
                                                                    </Grid>
                                                                </DataTemplate>

                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>


                                                        <!-- Добавление новой пары Source + Destination -->
                                                        <Grid Grid.Row="1" Margin="0,10,0,0">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" SharedSizeGroup="Labels"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                                       Text="Source:"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,5,0,0"/>
                                                            <TextBox x:Name="SourceTextBox"
                                                                     Grid.Row="0" Grid.Column="1"
                                                                     Height="25"
                                                                     VerticalContentAlignment="Center"
                                                                     MinWidth="200"
                                                                     Margin="10,5,0,0"/>

                                                            <TextBlock Grid.Row="1" Grid.Column="0"
                                                                       Text="Destination:"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,5,0,0"/>
                                                            <TextBox x:Name="DestinationTextBox"
                                                                     Grid.Row="1" Grid.Column="1"
                                                                     Height="25"
                                                                     Margin="10,5,0,0"
                                                                     VerticalContentAlignment="Center"
                                                                     MinWidth="200"/>

                                                            <Button Grid.Row="2" Grid.Column="1"
                                                                    Content="Add"
                                                                    Command="{Binding AddDeliveryDirectoryCommand}"
                                                                    Style="{StaticResource CustomButtonStyle}"
                                                                    HorizontalAlignment="Right"
                                                                    Margin="0,10,0,0"
                                                                    MinWidth="70"
                                                                    Height="25">
                                                                <Button.CommandParameter>
                                                                    <MultiBinding Converter="{StaticResource DeliveryDirectoryConverter}">
                                                                        <Binding ElementName="SourceTextBox" Path="Text"/>
                                                                        <Binding ElementName="DestinationTextBox" Path="Text"/>
                                                                    </MultiBinding>
                                                                </Button.CommandParameter>
                                                            </Button>
                                                        </Grid>
                                                    </Grid>
                                                </GroupBox>


                                            </StackPanel>
                                        </Expander>
                                        <!-- Delivery Settings -->
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>