<Page
    x:Class="ServerMultiTool.Features.InternalTools.InternalToolsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:generalInfo="clr-namespace:ServerMultiTool.Shared.Components.GeneralInfo"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:internalTools="clr-namespace:ServerMultiTool.Features.InternalTools"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{Binding Title}"
    d:DataContext="{d:DesignInstance Type=internalTools:InternalToolsViewModel, IsDesignTimeCreatable=True}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    FontFamily="Poppins"
    mc:Ignorable="d">

    <Border Background="{DynamicResource SecondaryBackgroundColor}" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <generalInfo:GeneralInfoControl
                Grid.Row="0"
                Margin="10"
                DataContext="{Binding GeneralInfo}" />

            <Border
                Grid.Row="1"
                Margin="10"
                Padding="24"
                Background="{DynamicResource TertiaryBackgroundColor}"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="28"
                        FontWeight="Bold"
                        Foreground="{DynamicResource PrimaryTextColor}"
                        Text="Internal Tools demo module" />
                    <TextBlock
                        Margin="0,12,0,0"
                        Foreground="{DynamicResource SecondaryTextColor}"
                        Text="Эта вкладка добавлена через модульный descriptor и служит живым шаблоном для новых интеграций." />

                    <Border
                        Margin="0,24,0,0"
                        Padding="16"
                        Background="{DynamicResource SecondaryBackgroundColor}"
                        CornerRadius="6">
                        <StackPanel>
                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource PrimaryTextColor}"
                                Text="Что нужно для новой вкладки" />
                            <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource PrimaryTextColor}" Text="1. Создать View и ViewModel внутри feature-папки." />
                            <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource PrimaryTextColor}" Text="2. Добавить Add&lt;Feature&gt;Module() с descriptor-регистрацией." />
                            <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource PrimaryTextColor}" Text="3. Использовать INavigationService для переходов между вкладками." />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Page>

