<Page
    x:Class="ServerMultiTool.Features.Settings.Presentation.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:generalInfo="clr-namespace:ServerMultiTool.Shared.Components.GeneralInfo"
    xmlns:profileEditor="clr-namespace:ServerMultiTool.Shared.Components.ProfileEditor"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="clr-namespace:ServerMultiTool.ViewModels.Converters"
    Title="{Binding Title}"
    d:DesignHeight="750"
    d:DesignWidth="700"
    FontFamily="Poppins"
    mc:Ignorable="d">
    <!--  d:DataContext="{d:DesignInstance Type=settings:SettingsViewModel, IsDesignTimeCreatable=True}"  -->

    <Page.Resources>
        <converters:StringNotNullOrEmptyToBoolConverter x:Key="StringNotNullOrEmptyToBoolConverter" />
        <Style x:Key="PanelHeaderBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundColor}" />
            <Setter Property="BorderBrush" Value="LightGray" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
        <Style x:Key="PanelHeaderTitleStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}" />
        </Style>
        <Style x:Key="SmallAddButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource TertiaryBackgroundColor}" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryBlueColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SecondaryBlueColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="{TemplateBinding FontSize}"
                                Foreground="{TemplateBinding Foreground}"
                                Text="{TemplateBinding Content}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryWhiteColor}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryRedColor}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center" Data="M9,3V4H4V6H5V19A2,2 0 0,0 7,21H17A2,2 0 0,0 19,19V6H20V4H15V3H9M7,6H17V19H7V6M9,8V17H11V8H9M13,8V17H15V8H13Z" Fill="{DynamicResource PrimaryRedColor}" Stretch="Uniform" />
                            <TextBlock VerticalAlignment="Center" FontSize="{TemplateBinding FontSize}" Foreground="{DynamicResource PrimaryRedColor}" Text="{TemplateBinding Content}" />
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Border Background="{DynamicResource SecondaryBackgroundColor}" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <generalInfo:GeneralInfoControl
                Grid.Row="0"
                Margin="10"
                DataContext="{Binding GeneralInfo}" />

            <TabControl
                Grid.Row="1"
                Margin="10,10,10,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                IsEnabled="{Binding GeneralInfo.CanChangeStates}"
                SelectedValue="{Binding SelectedTabKey, Mode=TwoWay}"
                SelectedValuePath="Tag">
                <TabControl.Resources>
                    <Style BasedOn="{StaticResource {x:Type TabItem}}" TargetType="TabItem">
                        <Setter Property="FontSize" Value="15" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border
                                        Name="Border"
                                        Margin="2,0,2,-1"
                                        Padding="0,0,0,2"
                                        BorderBrush="Gainsboro"
                                        BorderThickness="1,1,1,0"
                                        CornerRadius="4,4,0,0">
                                        <ContentPresenter
                                            x:Name="ContentSite"
                                            Margin="10,2"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            ContentSource="Header" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Panel.ZIndex" Value="1" />
                                            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextColor}" />
                                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource TertiaryBackgroundColor}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}" />
                                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource SecondaryBackgroundColor}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!--  General Tab  -->
                <TabItem Header="General" Tag="General">
                    <Border
                        Padding="10"
                        BorderBrush="Gainsboro"
                        BorderThickness="0.8">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Solution Directories  -->
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Label
                                    Grid.Row="0"
                                    Content="Solution Directories:"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource PrimaryTextColor}" />

                                <ListBox
                                    Grid.Row="1"
                                    Padding="5"
                                    VerticalAlignment="Stretch"
                                    Background="{DynamicResource TertiaryBackgroundColor}"
                                    Foreground="{DynamicResource PrimaryTextColor}"
                                    ItemsSource="{Binding SolutionDirectories}"
                                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                    SelectedItem="{Binding SelectedSolutionDirectory}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,5" Orientation="Vertical">
                                                <DockPanel Margin="0,0,0,5" LastChildFill="True">
                                                    <TextBlock
                                                        Width="50"
                                                        Margin="0,0,5,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource SecondaryTextColor}"
                                                        Text="Name:" />
                                                    <TextBox
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        FontSize="13"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource PrimaryTextColor}"
                                                        Text="{Binding Name}" />
                                                </DockPanel>
                                                <DockPanel LastChildFill="True">
                                                    <TextBlock
                                                        Width="50"
                                                        Margin="0,0,5,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource SecondaryTextColor}"
                                                        Text="Path:" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="13"
                                                        Foreground="{DynamicResource SecondaryTextColor}"
                                                        Text="{Binding Path}"
                                                        TextTrimming="CharacterEllipsis"
                                                        TextWrapping="NoWrap" />
                                                    <Button
                                                        Width="30"
                                                        Height="20"
                                                        Margin="5,0,0,0"
                                                        BorderBrush="Black"
                                                        BorderThickness="0.5"
                                                        Command="{Binding DataContext.SelectDirectoryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        Content="..."
                                                        Style="{StaticResource CustomButtonStyle}" />
                                                </DockPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <StackPanel
                                    Grid.Row="2"
                                    Margin="0,5,0,0"
                                    HorizontalAlignment="Left"
                                    Orientation="Horizontal">
                                    <Button
                                        Height="30"
                                        MinWidth="60"
                                        Margin="0,0,5,0"
                                        Command="{Binding AddSolutionDirectoryCommand}"
                                        Content="Add"
                                        Style="{StaticResource CustomButtonStyle}" />
                                    <Button
                                        Height="30"
                                        MinWidth="60"
                                        Command="{Binding RemoveSolutionDirectoryCommand}"
                                        CommandParameter="{Binding SelectedSolutionDirectory}"
                                        Content="Delete"
                                        Style="{StaticResource CustomButtonStyle}" />
                                </StackPanel>
                            </Grid>

                            <!--  Http Directories  -->
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Label
                                    Grid.Row="0"
                                    Content="Http Directories:"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource PrimaryTextColor}" />

                                <ListBox
                                    Grid.Row="1"
                                    Padding="5"
                                    VerticalAlignment="Stretch"
                                    Background="{DynamicResource TertiaryBackgroundColor}"
                                    Foreground="{DynamicResource PrimaryTextColor}"
                                    ItemsSource="{Binding HttpDirectories}"
                                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                    SelectedItem="{Binding SelectedHttpDirectory}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,5" Orientation="Vertical">
                                                <DockPanel Margin="0,0,0,5" LastChildFill="True">
                                                    <TextBlock
                                                        Width="50"
                                                        Margin="0,0,5,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource SecondaryTextColor}"
                                                        Text="Name:" />
                                                    <TextBox
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        FontSize="13"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource PrimaryTextColor}"
                                                        Text="{Binding Name}" />
                                                </DockPanel>
                                                <DockPanel LastChildFill="True">
                                                    <TextBlock
                                                        Width="50"
                                                        Margin="0,0,5,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource SecondaryTextColor}"
                                                        Text="Path:" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="13"
                                                        Foreground="{DynamicResource SecondaryTextColor}"
                                                        Text="{Binding Path}"
                                                        TextTrimming="CharacterEllipsis"
                                                        TextWrapping="NoWrap" />
                                                    <Button
                                                        Width="30"
                                                        Height="20"
                                                        Margin="5,0,0,0"
                                                        BorderBrush="Black"
                                                        BorderThickness="0.5"
                                                        Command="{Binding DataContext.SelectDirectoryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        Content="..."
                                                        Style="{StaticResource CustomButtonStyle}" />
                                                </DockPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <StackPanel
                                    Grid.Row="2"
                                    Margin="0,5,0,0"
                                    HorizontalAlignment="Left"
                                    Orientation="Horizontal">
                                    <Button
                                        Height="30"
                                        MinWidth="60"
                                        Margin="0,0,5,0"
                                        Command="{Binding AddHttpDirectoryCommand}"
                                        Content="Add"
                                        Style="{StaticResource CustomButtonStyle}" />
                                    <Button
                                        Height="30"
                                        MinWidth="60"
                                        Command="{Binding RemoveHttpDirectoryCommand}"
                                        CommandParameter="{Binding SelectedHttpDirectory}"
                                        Content="Delete"
                                        Style="{StaticResource CustomButtonStyle}" />
                                </StackPanel>
                            </Grid>

                            <!--  Auto-Update Settings  -->
                            <Grid Grid.Row="2" Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Label
                                    Grid.Row="0"
                                    Content="Auto Update:"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource PrimaryTextColor}" />

                                <!--  Feed URL  -->
                                <DockPanel Grid.Row="1" Margin="0,4,0,8" LastChildFill="True">
                                    <TextBlock
                                        Width="170"
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource SecondaryTextColor}"
                                        Text="Appcast URL:" />
                                    <TextBox
                                        Height="28"
                                        Padding="4,2"
                                        Background="{DynamicResource TertiaryBackgroundColor}"
                                        BorderBrush="Gray"
                                        BorderThickness="0.8"
                                        FontSize="13"
                                        Foreground="{DynamicResource PrimaryTextColor}"
                                        Text="{Binding UpdateFeedUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        ToolTip="URL to the appcast XML file (e.g. https://example.com/appcast.xml)" />
                                </DockPanel>

                                <!--  Ed25519 public key  -->
                                <DockPanel Grid.Row="2" Margin="0,0,0,8" LastChildFill="True">
                                    <TextBlock
                                        Width="170"
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource SecondaryTextColor}"
                                        Text="Ed25519 Public Key:" />
                                    <TextBox
                                        Height="28"
                                        Padding="4,2"
                                        Background="{DynamicResource TertiaryBackgroundColor}"
                                        BorderBrush="Gray"
                                        BorderThickness="0.8"
                                        FontSize="13"
                                        Foreground="{DynamicResource PrimaryTextColor}"
                                        Text="{Binding UpdatePublicKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        ToolTip="Base64 public key used by NetSparkle to verify update signatures" />
                                </DockPanel>

                                <!--  Check on startup  -->
                                <DockPanel Grid.Row="3" Margin="0,0,0,8" LastChildFill="False">
                                    <TextBlock
                                        Width="170"
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource SecondaryTextColor}"
                                        Text="Check on Startup:" />
                                    <CheckBox
                                        VerticalAlignment="Center"
                                        IsChecked="{Binding CheckForUpdatesOnStartup, Mode=TwoWay}"
                                        ToolTip="Automatically check for updates when the application starts" />
                                </DockPanel>

                                <!--  Manual check button  -->
                                <StackPanel Grid.Row="4" Orientation="Horizontal">
                                    <Button
                                        Height="30"
                                        MinWidth="140"
                                        Command="{Binding CheckForUpdatesCommand}"
                                        Content="Check for Updates Now"
                                        IsEnabled="{Binding UpdateFeedUrl, Converter={StaticResource StringNotNullOrEmptyToBoolConverter}}"
                                        Style="{StaticResource CustomButtonStyle}" />
                                </StackPanel>
                            </Grid>

                        </Grid>
                        </ScrollViewer>
                    </Border>
                </TabItem>

                <!--  Pipeline Profiles Tab  -->
                <TabItem Header="Pipeline Profiles" Tag="PipelineProfiles">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="240" MinWidth="160" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--  LEFT: Pipeline Profiles List  -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource PanelHeaderBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Style="{StaticResource PanelHeaderTitleStyle}" Text="Pipeline Profiles" />
                                    <Button
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Command="{Binding AddPipelineProfileCommand}"
                                        Content="Add Profile"
                                        Style="{StaticResource SmallAddButtonStyle}" />
                                </Grid>
                            </Border>

                            <ListBox
                                Grid.Row="1"
                                Padding="4"
                                Background="{DynamicResource TertiaryBackgroundColor}"
                                Foreground="{DynamicResource PrimaryTextColor}"
                                IsSynchronizedWithCurrentItem="True"
                                ItemsSource="{Binding PipelineProfiles}"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                SelectedItem="{Binding SelectedPipelineProfile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="4,2" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="itemBorder" Padding="0" Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="itemBorder" Property="Background" Value="#DCE6FF" />
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="itemBorder" Property="Background" Value="#EEF3FF" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,8" BorderBrush="LightGray" BorderThickness="1.5" CornerRadius="6">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource TertiaryBackgroundColor}" />
                                                    <Setter Property="BorderBrush" Value="LightGray" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource SecondaryBlueColor}" />
                                                            <Setter Property="Background" Value="#EFF4FF" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource PrimaryTextColor}"
                                                        Text="{Binding Name}"
                                                        TextTrimming="CharacterEllipsis" />
                                                    <TextBlock
                                                        Margin="0,2,0,0"
                                                        FontSize="11"
                                                        Foreground="{DynamicResource PrimaryGrayColor}"
                                                        Text="{Binding Description}"
                                                        TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <Button
                                                    Grid.Column="1"
                                                    Width="24"
                                                    Height="24"
                                                    VerticalAlignment="Top"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Command="{Binding DataContext.RemovePipelineProfileCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}"
                                                    Content=""
                                                    Cursor="Hand"
                                                    Style="{StaticResource DeleteButtonStyle}"
                                                    ToolTip="Remove profile" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <Border Grid.Column="1" Background="LightGray" />

                        <!--  RIGHT: Profile Editor  -->
                        <Grid Grid.Column="2">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource SecondaryTextColor}"
                                Text="Select a profile to edit its settings"
                                TextAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedPipelineProfile}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <profileEditor:EditPipelineProfileControl DataContext="{Binding EditPipelineProfile}">
                                <profileEditor:EditPipelineProfileControl.Style>
                                    <Style TargetType="profileEditor:EditPipelineProfileControl">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.SelectedPipelineProfile, RelativeSource={RelativeSource AncestorType=Grid}}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </profileEditor:EditPipelineProfileControl.Style>
                            </profileEditor:EditPipelineProfileControl>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>

            <!--  Save/Cancel buttons  -->
            <StackPanel
                Grid.Row="2"
                Margin="10"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    Height="35"
                    MinWidth="70"
                    Margin="0,0,10,0"
                    Command="{Binding CancelSettingsCommand}"
                    Content="Cancel"
                    IsEnabled="{Binding HasUnsavedChanges}"
                    Style="{StaticResource CustomButtonStyle}" />
                <Button
                    Height="35"
                    MinWidth="70"
                    Command="{Binding SaveSettingsCommand}"
                    Content="Save"
                    IsEnabled="{Binding HasUnsavedChanges}"
                    Style="{StaticResource CustomButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Page>


