<Page
    x:Class="ServerMultiTool.Features.Settings.Presentation.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:generalInfo="clr-namespace:ServerMultiTool.Shared.Components.GeneralInfo"
    xmlns:profileEditor="clr-namespace:ServerMultiTool.Shared.Components.ProfileEditor"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settings="clr-namespace:ServerMultiTool.Features.Settings.Presentation"
    Title="{Binding Title}"
    d:DesignHeight="750"
    d:DesignWidth="700"
    FontFamily="Poppins"
    mc:Ignorable="d">
    <!--  d:DataContext="{d:DesignInstance Type=settings:SettingsViewModel, IsDesignTimeCreatable=True}"  -->

    <Border Background="{DynamicResource SecondaryBackgroundColor}" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <generalInfo:GeneralInfoControl
                Grid.Row="0"
                Margin="10"
                DataContext="{Binding GeneralInfo}" />

            <TabControl
                Grid.Row="1"
                Margin="10,10,10,0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                IsEnabled="{Binding GeneralInfo.CanChangeStates}"
                SelectedValue="{Binding SelectedTabKey, Mode=TwoWay}"
                SelectedValuePath="Tag">
                <TabControl.Resources>
                    <Style BasedOn="{StaticResource {x:Type TabItem}}" TargetType="TabItem">
                        <Setter Property="FontSize" Value="15" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border
                                        Name="Border"
                                        Margin="2,0,2,-1"
                                        Padding="0,0,0,2"
                                        BorderBrush="Gainsboro"
                                        BorderThickness="1,1,1,0"
                                        CornerRadius="4,4,0,0">
                                        <ContentPresenter
                                            x:Name="ContentSite"
                                            Margin="10,2"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            ContentSource="Header" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Panel.ZIndex" Value="1" />
                                            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextColor}" />
                                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource TertiaryBackgroundColor}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}" />
                                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource SecondaryBackgroundColor}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!--  General Tab  -->
                <TabItem Header="General" Tag="General">
                    <Border
                        Padding="10"
                        BorderBrush="Gainsboro"
                        BorderThickness="0.8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!--  Solution Directories  -->
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Label
                                    Grid.Row="0"
                                    Content="Solution Directories:"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource PrimaryTextColor}" />

                                <ListBox
                                    Grid.Row="1"
                                    Padding="5"
                                    VerticalAlignment="Stretch"
                                    Background="{DynamicResource TertiaryBackgroundColor}"
                                    Foreground="{DynamicResource PrimaryTextColor}"
                                    ItemsSource="{Binding SolutionDirectories}"
                                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                    SelectedItem="{Binding SelectedSolutionDirectory}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,5" Orientation="Vertical">
                                                <DockPanel Margin="0,0,0,5" LastChildFill="True">
                                                    <TextBlock
                                                        Width="50"
                                                        Margin="0,0,5,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource SecondaryTextColor}"
                                                        Text="Name:" />
                                                    <TextBox
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        FontSize="13"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource PrimaryTextColor}"
                                                        Text="{Binding Name}" />
                                                </DockPanel>
                                                <DockPanel LastChildFill="True">
                                                    <TextBlock
                                                        Width="50"
                                                        Margin="0,0,5,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource SecondaryTextColor}"
                                                        Text="Path:" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="13"
                                                        Foreground="{DynamicResource SecondaryTextColor}"
                                                        Text="{Binding Path}"
                                                        TextTrimming="CharacterEllipsis"
                                                        TextWrapping="NoWrap" />
                                                    <Button
                                                        Width="30"
                                                        Height="20"
                                                        Margin="5,0,0,0"
                                                        BorderBrush="Black"
                                                        BorderThickness="0.5"
                                                        Command="{Binding DataContext.SelectDirectoryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        Content="..."
                                                        Style="{StaticResource CustomButtonStyle}" />
                                                </DockPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <StackPanel
                                    Grid.Row="2"
                                    Margin="0,5,0,0"
                                    HorizontalAlignment="Left"
                                    Orientation="Horizontal">
                                    <Button
                                        Height="30"
                                        MinWidth="60"
                                        Margin="0,0,5,0"
                                        Command="{Binding AddSolutionDirectoryCommand}"
                                        Content="Add"
                                        Style="{StaticResource CustomButtonStyle}" />
                                    <Button
                                        Height="30"
                                        MinWidth="60"
                                        Command="{Binding RemoveSolutionDirectoryCommand}"
                                        CommandParameter="{Binding SelectedSolutionDirectory}"
                                        Content="Delete"
                                        Style="{StaticResource CustomButtonStyle}" />
                                </StackPanel>
                            </Grid>

                            <!--  Http Directories  -->
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Label
                                    Grid.Row="0"
                                    Content="Http Directories:"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource PrimaryTextColor}" />

                                <ListBox
                                    Grid.Row="1"
                                    Padding="5"
                                    VerticalAlignment="Stretch"
                                    Background="{DynamicResource TertiaryBackgroundColor}"
                                    Foreground="{DynamicResource PrimaryTextColor}"
                                    ItemsSource="{Binding HttpDirectories}"
                                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                    SelectedItem="{Binding SelectedHttpDirectory}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,5" Orientation="Vertical">
                                                <DockPanel Margin="0,0,0,5" LastChildFill="True">
                                                    <TextBlock
                                                        Width="50"
                                                        Margin="0,0,5,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource SecondaryTextColor}"
                                                        Text="Name:" />
                                                    <TextBox
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        FontSize="13"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource PrimaryTextColor}"
                                                        Text="{Binding Name}" />
                                                </DockPanel>
                                                <DockPanel LastChildFill="True">
                                                    <TextBlock
                                                        Width="50"
                                                        Margin="0,0,5,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource SecondaryTextColor}"
                                                        Text="Path:" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="13"
                                                        Foreground="{DynamicResource SecondaryTextColor}"
                                                        Text="{Binding Path}"
                                                        TextTrimming="CharacterEllipsis"
                                                        TextWrapping="NoWrap" />
                                                    <Button
                                                        Width="30"
                                                        Height="20"
                                                        Margin="5,0,0,0"
                                                        BorderBrush="Black"
                                                        BorderThickness="0.5"
                                                        Command="{Binding DataContext.SelectDirectoryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        Content="..."
                                                        Style="{StaticResource CustomButtonStyle}" />
                                                </DockPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <StackPanel
                                    Grid.Row="2"
                                    Margin="0,5,0,0"
                                    HorizontalAlignment="Left"
                                    Orientation="Horizontal">
                                    <Button
                                        Height="30"
                                        MinWidth="60"
                                        Margin="0,0,5,0"
                                        Command="{Binding AddHttpDirectoryCommand}"
                                        Content="Add"
                                        Style="{StaticResource CustomButtonStyle}" />
                                    <Button
                                        Height="30"
                                        MinWidth="60"
                                        Command="{Binding RemoveHttpDirectoryCommand}"
                                        CommandParameter="{Binding SelectedHttpDirectory}"
                                        Content="Delete"
                                        Style="{StaticResource CustomButtonStyle}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </TabItem>

                <!--  Pipeline Profiles Tab  -->
                <TabItem Header="Pipeline Profiles" Tag="PipelineProfiles">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <Border
                            Padding="10"
                            BorderBrush="Gainsboro"
                            BorderThickness="0.8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" MinHeight="200" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!--  Pipeline Profiles List  -->
                                <DockPanel Grid.Row="0" Margin="0,0,0,20">

                                    <StackPanel
                                        Margin="0,5,0,0"
                                        HorizontalAlignment="Left"
                                        DockPanel.Dock="Bottom"
                                        Orientation="Horizontal">
                                        <Button
                                            Height="30"
                                            MinWidth="60"
                                            Margin="0,0,5,0"
                                            Command="{Binding AddPipelineProfileCommand}"
                                            Content="Add"
                                            Style="{StaticResource CustomButtonStyle}" />
                                        <Button
                                            Height="30"
                                            MinWidth="60"
                                            Command="{Binding RemovePipelineProfileCommand}"
                                            CommandParameter="{Binding SelectedPipelineProfile}"
                                            Content="Delete"
                                            Style="{StaticResource CustomButtonStyle}" />
                                    </StackPanel>

                                    <ListBox
                                        MinHeight="150"
                                        MaxHeight="250"
                                        Padding="5"
                                        Background="{DynamicResource TertiaryBackgroundColor}"
                                        Foreground="{DynamicResource PrimaryTextColor}"
                                        IsSynchronizedWithCurrentItem="True"
                                        ItemsSource="{Binding PipelineProfiles}"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                        SelectedItem="{Binding SelectedPipelineProfile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBox
                                                    Margin="0,10,0,10"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    FontSize="13"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource PrimaryTextColor}"
                                                    Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                </DockPanel>

                                <!--  Profile Editor  -->
                                <DockPanel Grid.Row="1">
                                    <Label
                                        Margin="0,0,0,5"
                                        Content="Edit Pipeline Profile"
                                        DockPanel.Dock="Top"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource PrimaryTextColor}" />


                                    <Border
                                        Padding="5"
                                        Background="{DynamicResource TertiaryBackgroundColor}"
                                        BorderBrush="LightGray"
                                        BorderThickness="1"
                                        CornerRadius="5">

                                        <Grid>
                                            <!--  Message when profile is not selected  -->
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="{DynamicResource SecondaryTextColor}"
                                                Text="Select a profile to edit its settings"
                                                TextAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedPipelineProfile}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!--  Profile Edit Settings  -->
                                            <profileEditor:EditPipelineProfileControl DataContext="{Binding EditPipelineProfile}">
                                                <profileEditor:EditPipelineProfileControl.Style>
                                                    <Style TargetType="profileEditor:EditPipelineProfileControl">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DataContext.SelectedPipelineProfile, RelativeSource={RelativeSource AncestorType=Grid}}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </profileEditor:EditPipelineProfileControl.Style>
                                            </profileEditor:EditPipelineProfileControl>
                                        </Grid>
                                    </Border>
                                </DockPanel>
                            </Grid>
                        </Border>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <!--  Save/Cancel buttons  -->
            <StackPanel
                Grid.Row="2"
                Margin="10"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    Height="35"
                    MinWidth="70"
                    Margin="0,0,10,0"
                    Command="{Binding CancelSettingsCommand}"
                    Content="Cancel"
                    IsEnabled="{Binding HasUnsavedChanges}"
                    Style="{StaticResource CustomButtonStyle}" />
                <Button
                    Height="35"
                    MinWidth="70"
                    Command="{Binding SaveSettingsCommand}"
                    Content="Save"
                    IsEnabled="{Binding HasUnsavedChanges}"
                    Style="{StaticResource CustomButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Page>
